// Temple Trials: Room 5 / Sarcophagus / Champion of Bhaal ******************************************************************************************************************************************* 
// Map 
LOAD_TRA ~CDB\LANGUAGE\FRENCH\COM021.TRA~ 
COPY ~CDB\area\COM021.are~ ~override~ 

  // Add the message from the blocked coffin 
	SET My_Message = RESOLVE_STR_REF (@6) 

	READ_LONG 0x70 "cont_off" // Offset to containers 
	READ_SHORT 0x74 "cont_num" // Count of containers 

	FOR (k = 0; k < cont_num; ++k) BEGIN // For each container

		READ_ASCII ("%cont_off%" + (0xC0 * k)) "contain" (32) NULL 

		PATCH_MATCH ~%contain%~ WITH 
			S2cercueil1 BEGIN WRITE_LONG ("%cont_off%" + 0x84 + (0xC0 * k)) Mon_Message END 
			DEFAULT 
		END 
	END 
COPY ~CDB\area\COM021.mos~ ~override~ 
COPY_LARGE ~CDB\area\COM021.tis~ ~override~ 
COPY ~CDB\area\COM021.wed~ ~override~ 
COPY ~CDB\area\COM021HT.bmp~ ~override~ 
