// Installation verification *************************************************************************************************************************************** 
// Prerequisites:BGT installation 
//REQUIRE_PREDICATE (GAME_IS ~bgt~) @5 

/* 
// Prerequisite: TOB installation 
REQUIRE_PREDICATE (FILE_EXISTS ~tobex.dll~) @6 
*/ 

// Checking NI installation and loading creatures with optional animations
// MOD AI installed 
ACTION_IF (FILE_EXISTS_IN_GAME "setup-infinityanimations.tp2") BEGIN 
  PRINT @7 
  LOAD_TRA ~CDB\LANGUAGE\Noms.TRA~ 


  // Part 1 *************** 
  // Merchant Animation -> Deep Water Merchant (Helm and Cloak Inn) - AR7216 / 0xc800 -> 0x5d57 
  ACTION_IF (FILE_EXISTS_IN_GAME "�bag1.bam") BEGIN 
	  PRINT ~Merchant~ 
	  COPY ~CDB\CRE\Animation\COMER01.cre~ ~override~ // Merchant 
	  SAY NAME1 @6   

	  COPY ~CDB\CRE\Animation\COMER02.cre~ ~override~ // Merchant 
	  SAY NAME1 @6   

  END ELSE BEGIN 
	  COPY ~CDB\CRE\COMER01.cre~ ~override~ // Merchant 
	  SAY NAME1 @6   

	  COPY ~CDB\CRE\COMER02.cre~ ~override~ // Merchant 
	  SAY NAME1 @6   
  END 

  // Animation Mummy> Harpy (Level 1B) - COM015 / x -> 0x5269 
  ACTION_IF (FILE_EXISTS_IN_GAME "�bsa1.bam") BEGIN 
  	  PRINT ~Harpy~ 
	  COPY ~CDB\CRE\Animation\COHARP1.cre~ ~override~ // Harpy 
	  SAY NAME1 @303 

  END ELSE BEGIN 
	  COPY ~CDB\CRE\COHARP1.cre~ ~override~ // Harpy -> mummy 
	  SAY NAME1 @304 
  END 

  // Rock Shadow Animation -> Rock Shadow ICEWIND (Level 1B) - COM015 / 0x7f11 -> 0xe0d0 
  ACTION_IF (FILE_EXISTS_IN_GAME "mumba1.bam") BEGIN 
	  PRINT ~Rock Shadow~ 
	  COPY ~CDB\CRE\Animation\COUMBER.cre~ ~override~ // UmberHulk 

  END ELSE BEGIN 
	  COPY ~CDB\CRE\COUMBER.cre~ ~override~ // UmberHulk 
  END 

  // Animation Syst�ra Lich -> IceWIND Syst�ra Lich (Level 2) - COM017 / 0x7f0d -> 0xe060 
  ACTION_IF (FILE_EXISTS_IN_GAME "") BEGIN 
  	  PRINT ~Liche~ 
	  COPY ~CDB\CRE\Animation\COSYSTE.cre~ ~override~ // Syst�ra 
	  SAY NAME1 @298 
	  SAY NAME2 @298 

  END ELSE BEGIN 
	  COPY ~CDB\CRE\COSYSTE.cre~ ~override~ // Syst�ra 
	  SAY NAME1 @298 
	  SAY NAME2 @298 
  END 


  // Part 2 *************** 
  // Animation Witch Sickness -> witch Sickness ICEWIND () - COM024 / x -> 0xe0f2 wailing_virgin 
  ACTION_IF (FILE_EXISTS_IN_GAME "") BEGIN 
         PRINT ~Witch~ 
	 COPY ~CDB\CRE\Animation\COMALAD.cre~ ~override~ // SICKNESS 
	 SAY NAME1 @290 
	 SAY NAME2 @290 

  END ELSE BEGIN 
	 COPY ~CDB\CRE\COMALAD.cre~ ~override~ // DISEASE 
	 SAY NAME1 @290 
	 SAY NAME2 @290 
  END 

  // Spider Animation -> Giant Spider () - COM024 / x -> 0x5032 
  ACTION_IF (FILE_EXISTS_IN_GAME "�bya1.bam") BEGIN
       	  PRINT ~Giant Spider~ 
	  COPY ~CDB\CRE\Animation\COSPIDG.cre~ ~override~ // Giant Spider (Transformed Disease) 
	  SAY NAME1 @290 
	  SAY NAME2 @290 

  END ELSE BEGIN 
	  COPY ~CDB\CRE\COSPIDG.cre~ ~override~ // Giant Spider (Transformed Disease) 
	  SAY NAME1 @290 
	  SAY NAME2 @290 
  END 

  // Animation Basilik -> Basilik ICEWIND () - COM022 / 0x7101 basilisk_greater -> 0x557B 
  ACTION_IF (FILE_EXISTS_IN_GAME "�jxg1.bam") BEGIN 
	  PRINT ~Basilik~ 
	  COPY ~CDB\CRE\Animation\cobasil1.cre~ ~override~ // Basilik Glabuk 
	  SAY NAME1 @297 

  END ELSE BEGIN 
	  COPY ~CDB\CRE\cobasil1.cre~ ~override~ // Basilik Glabuk 
	  SAY NAME1 @297 
  END 

  // Cockroach Animation -> [ID]Beetle Fire- COM021 / -> 0xe210 beetle_fire 
  ACTION_IF (FILE_EXISTS_IN_GAME "mbfi.2da") BEGIN 
	  PRINT ~Cafard~ 
	  COPY ~CDB\CRE\Animation\cobeet1.cre~ ~override~ // beetle_fire 
	  SAY NAME1 @297 

  END ELSE BEGIN 
	  COPY ~CDB\CRE\cobeet1.cre~ ~override~ // 
	  SAY NAME1 @297 
  END 
 
 // Infinity animation not installed ********************************************************************************* 
 END ELSE BEGIN 
  PRINT @9 
  //The Infinity Animation mod is not installed. You will not benefit from the animation additions. Do you want to? 
  //[1] Stop the installation and install the AI ​​mod first. 
  //[2] Install without the AI ​​mod. 

   ACTION_READLN ~reply2~ 
   OUTER_WHILE ((~%reply2%~ STRING_EQUAL_CASE ~1~ = 0) AND (~%reply2%~ STRING_EQUAL_CASE ~2~ = 0)) BEGIN 
   PRINT @9   
   ACTION_READLN ~reply2~ 
  END 

  // Choice [1] made 
  ACTION_IF (~%reply2%~ STRING_EQUAL_CASE ~1~ = 1) BEGIN 
   PRINT @2 // Choice [1] made 
  END 

  // Choice [2] made 
 ACTION_IF (~%reply2%~ STRING_EQUAL_CASE ~2~ = 1) BEGIN 
  PRINT @3 // Choice [2] made 

  PRINT @8 

  LOAD_TRA ~CDB\LANGUAGE\Noms.TRA~ 
  // Merchant Animation -> Deep Water Merchant (Helm and Cloak Inn) - AR7216 
  COPY ~CDB\CRE\COMER01.cre~ ~override~ // Merchant 
  SAY NAME1 @6   

  COPY ~CDB\CRE\COMER02.cre~ ~override~ // Merchant 
  SAY NAME1 @6   

  // Mummy > Harpy Animation (Level 1B) - COM015 
  COPY ~CDB\CRE\COHARP1.cre~ ~override~ // Harpy -> Mummy 
  SAY NAME1 @304 

  // Shadow Rock -> Shadow Rock ICEWIND Animation (Level 1B) - COM015
  COPY ~CDB\CRE\COUMBER.cre~ ~override~ // UmberHulk 

  // Animation Lich System -> Lich System ICEWIND (Level 2) - COM016 
  COPY ~CDB\CRE\COSYSTE.cre~ ~override~ // System 
  SAY NAME1 @298 
  SAY NAME2 @298 

  // Animation Witch Disease -> witch ICEWIND Disease () - COM024 
  COPY ~CDB\CRE\COMALAD.cre~ ~override~ // DISEASE 
  SAY NAME1 @290 
  SAY NAME2 @290 

  // Spider Animation -> Giant Spider () - COM024 
  COPY ~CDB\CRE\COSPIDG.cre~ ~override~ // Giant Spider (Transformed Disease) 
  SAY NAME1 @290 
  SAY NAME2 @290 

  // Basilik Animation -> Basilik ICEWIND () - COM022 
  COPY ~CDB\CRE\cobasil1.cre~ ~override~ // Basilik Glabuk 
  SAY NAME1 @297 

  END 
END 





// Mod startup choice ************************************************************************************************************************************************ 
LOAD_TRA ~CDB\LANGUAGE\French\Setup.tra~ 
PRINT @1 
//Do you want to? 
//[1] Activate the mod upon Sarevok's death (BG1 sequel). 
//[2] Start a game with the mod right away.~ 
ACTION_READLN ~reply~ 
 OUTER_WHILE ((~%reply%~ STRING_EQUAL_CASE ~1~ = 0) AND (~%reply%~ STRING_EQUAL_CASE ~2~ = 0)) BEGIN 
  PRINT @1   
  ACTION_READLN ~reply~ 
 END 

// Choice [1] made 
ACTION_IF (~%reply%~ STRING_EQUAL_CASE ~1~ = 1) BEGIN 
 PRINT @2 // Choice [1] made 
 EXTEND_TOP ~AR7225.bcs~ ~CDB\Setup\DEM_MOD1.baf~ // Add variable to activate the mod upon Sarevok's death. 
END 

// Choice [2] made 
ACTION_IF (~%reply%~ STRING_EQUAL_CASE ~2~ = 1) BEGIN 
  PRINT @3   
  EXTEND_TOP ~BALDUR.bcs~ ~CDB\Setup\DEM_MOD2.baf~ // Added variable to start the mod as soon as the BG2 game is launched. 
  EXTEND_TOP ~BALDUR25.bcs~ ~CDB\Setup\DEM_MOD2.baf~ // Added variable to start the mod as soon as the TOB game is launched. 
END 


