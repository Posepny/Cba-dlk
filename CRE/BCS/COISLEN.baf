// Les chauve_souris guident Islendra vers le groupe ***********************************************************************************************************************
IF
  Heard([0],50)
  !See([Pc])
THEN
  RESPONSE #100
  MoveToObject(Lastheardby(Myself))
  Continue()
END

IF
  Heard([0],60)
  !Heard([0],50)
  !See([Pc])
THEN
  RESPONSE #100
  MoveToObject(Lastheardby(Myself))
  Continue()
END

