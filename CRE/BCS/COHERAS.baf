// Gestion du nombre de larmes de Bhaal en leur possession
IF
 PartyHasItem("MISCP35")
 Global("larmes_1","com023",0)
THEN
 RESPONSE #100
 SetGlobal("larmes_1","com023",1)
 IncrementGlobal("NB_larmes_sang","com023",1)
END

