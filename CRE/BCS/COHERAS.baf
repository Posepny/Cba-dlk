// Départ dialogue
IF
 Global("Heras_dialogue","COM023",0)
THEN
 Response #100 
 SetGlobal("Heras_dialogue","COM023",1)
 StartDialogueNoSet(PLAYER1)
END

// Apparition du coffre
IF
 Global("Heras_coffre","COM023",1)
THEN
 RESPONSE #100
 SetGlobal("Heras_coffre","COM023",2)
 
 CloseDoor("DCoffre1")
 ContainerEnable("Coffre01",TRUE)
 PlaySound("EFF_E02")
 
 SetGlobal("Heras_destroy","COM023",1)
 
 Continue() 
END

IF
 Global("Heras_destroy","COM023",1)
THEN
 RESPONSE #100
 SetGlobal("Heras_destroy","COM023",0)
 DestroySelf()
END


