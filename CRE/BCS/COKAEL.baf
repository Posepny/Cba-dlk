// Kael entame le dialogue ****************************************************************************************************************************************************
// 1iere rencontre avec KAEL
IF
 Global("KAEL_rencontre","COM022",0)
 Global("Kael_vaincu","COM022",0)
 See([PC])
 Range([PC],10)
THEN
 RESPONSE #100 
 SetGlobal("KAEL_rencontre","COM022",1)
 SetInterrupt(TRUE)
  ActionOverride("COKAEL",FaceObject([PC]))
  SmallWait(20)
  StartDialogueNoSet([PC])  
 SetInterrupt(FALSE)
END


// Quęte de l'artéfact et Kael inconnu ****************************************************************************************************
IF
 Global("KAEL_quete_artefact","COM022",1)
 Global("KAEL_reconnu","COM022",0)
THEN
 RESPONSE #100 
 SetGlobal("KAEL_quete_artefact","COM022",2)
 AddJournalEntry(@300,QUEST)
END

// Quęte de l'artéfact et Kael reconnu
IF
 Global("KAEL_quete_artefact","COM022",1)
 Global("KAEL_reconnu","COM022",1)
THEN
 RESPONSE #100 
 SetGlobal("KAEL_quete_artefact","COM022",2)
 AddJournalEntry(@302,QUEST)
END

// CUTSCENE création de l'artefact Horreur guerričre
IF
Global("KAEL_artefact_creation","COM022",2)
THEN
 RESPONSE #100 
 SetGlobal("KAEL_artefact_creation","COM022",3)

 StartCutSceneMode()
 StartCutScene("COCS022A") 
END

// Artefact créé
IF
 See(PLAYER1)
 Global("KAEL_artefact_creation","COM022",4)
THEN
 RESPONSE #100 
 SetGlobal("KAEL_artefact_creation","COM022",5)

 StartDialogueNoSet(PLAYER1)  
END

// Quęte artefact réalisée
 // Kael non reconnu
IF
 Global("KAEL_reconnu","COM022",0)
 Global("KAEL_artefact_creation","COM022",6)
 Global("KAEL_quete_artefact","COM022",2)
THEN
 RESPONSE #100 
 SetGlobal("KAEL_quete_artefact","COM022",3)

 EraseJournalEntry(@300)
 AddJournalEntry(@301,QUEST_DONE) 

 AddexperienceParty(1000)    
END

// Quęte artefact réalisée
 // Kael reconnu
IF
 Global("KAEL_reconnu","COM022",1)
 Global("KAEL_artefact_creation","COM022",6)
 Global("KAEL_quete_artefact","COM022",2)
THEN
 RESPONSE #100 
 SetGlobal("KAEL_quete_artefact","COM022",3)

 EraseJournalEntry(@302)
 AddJournalEntry(@303,QUEST_DONE) 

 AddexperienceParty(1000)   
 GiveItem("MISCP64",PLAYER1)
END

// Kael allié et les autres Boss sont éliminés: dernier dialogue ****************************************************************************************************
IF
 Global("NB_boss_dead","COM024",6)
 Global("CO_KAEL_ALLIE","GLOBAL",1)
 Global("KAEL_FIN","COM024",0)
THEN
 RESPONSE #100
 SetGlobal("KAEL_FIN","COM024",1)
 //Createcreature("MINSC",[1400.720],10)
 //Createcreature("MINSC",[1400.720],10)
 
 SetInterrupt(FALSE)
  FaceObject(PLAYER1)
  SmallWait(20) 
  StartDialogueNoSet(PLAYER1)
 SetInterrupt(TRUE)
END








