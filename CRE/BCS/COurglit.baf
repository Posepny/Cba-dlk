// Urglit est vaincue par le feu (4 dťgats)
IF
 Global("Urglit_dmg_fire","COM021",4)
THEN
 RESPONSE #13
 DisplayStringHead(myself,@100)
 
 //CreateCreature("MINSC",[2700.1790],12) 
 StartDialogueNoSet([PC])
 Kill("COURGLIT")
END

// Si dťgats de feu, elle jubile.
IF
 See(Nearestenemyof(Myself))
 Global("Urglit_dmg_fire","COM021",1)
 OR(2)
  HitBy([ANYONE],MAGICFIRE)
  HitBy([ANYONE],FIRE)
THEN
 RESPONSE #12
 IncrementGlobal("Urglit_dmg_fire","COM021",1)
 DisplayStringHead(myself,@12)
END

// NiŤme dťg‚ts de feu
IF
 See(Nearestenemyof(Myself))
 GlobalGT("Urglit_dmg_fire","COM021",0)
 GlobalLT("Urglit_dmg_fire","COM021",4)
 OR(2)
  HitBy([ANYONE],MAGICFIRE)
  HitBy([ANYONE],FIRE)
THEN
 RESPONSE #24
 IncrementGlobal("Urglit_dmg_fire","COM021",1)
 DisplayStringHead(myself,@24)
END

// le groupe attaque Urglite
IF
  OR(2)
   HitBy([PC],CRUSHING)
   AttackedBy([PC],DEFAULT)
THEN
  RESPONSE #100
  Enemy()
  continue()
END

// Renouvellement des sorts
IF
  See(NearestEnemyOf(Myself))
  GLOBAL("Urglit_range1","LOCALS",0)
THEN
  RESPONSE #100
  SETGLOBAL("Urglit_range1","LOCALS",1)
  SetGlobalTimer("Urglit_SPELL","LOCALS",1)
END

// Combat corps ŗ corps
IF
 See(NearestEnemyOf(Myself))
 GlobalTimerExpired("Urglit_SPELL","LOCALS")
 Range(NearestEnemyOf(Myself),5)
 GlobalLT("Urglit_SPELL_range1","LOCALS",5)
THEN

  // CŰne de glace
  REsPONSE #100
  SetGlobalTimer("Urglit_SPELL","LOCALS",6)
  SpellNoDec(NearestEnemyOf(Myself),WIZARD_CONE_OF_COLD)
  IncrementGlobal("Urglit_SPELL_range1","LOCALS",1)
  
  // Toucher glacial
  REsPONSE #100
  SetGlobalTimer("Urglit_SPELL","LOCALS",6)
  SpellNoDec(Myself,WIZARD_CHILL_TOUCH)
  IncrementGlobal("Urglit_SPELL_range1","LOCALS",1)
  AttackOneRound(NearestEnemyOf(Myself))
  
  // Souffle glacial  
  RESPONSE #100
  SetGlobalTimer("Urglit_SPELL","LOCALS",6)
  SpellNoDecRes("COBREC1",NearestEnemyOf(Myself))
  IncrementGlobal("Urglit_SPELL_range1","LOCALS",1)
  
  // TempÍte de glace
  REsPONSE #100
  SetGlobalTimer("Urglit_SPELL","LOCALS",6)
  SpellNoDec(NearestEnemyOf(Myself),WIZARD_ICE_STORM)
  IncrementGlobal("Urglit_SPELL_rangeX","LOCALS",1)
END

// Combat ŗ distance
IF
 See(NearestEnemyOf(Myself))
 GlobalTimerExpired("Urglit_SPELL","LOCALS")
 !Range(NearestEnemyOf(Myself),5)
 GlobalLT("Urglit_SPELL_rangeX","LOCALS",5)
 !StateCheck(myself,STATE_HASTED)
THEN
  // Projectile de glace
  REsPONSE #100
  SetGlobalTimer("Urglit_SPELL","LOCALS",6)
  SpellNoDecRes("COSHAC1",NearestEnemyOf(Myself)) 
  IncrementGlobal("Urglit_SPELL_rangeX","LOCALS",1)
  
  // Rapiditť et attaque
  REsPONSE #100
  SetGlobalTimer("Urglit_SPELL","LOCALS",6)
  SpellNoDec(Myself,WIZARD_HASTE)
  IncrementGlobal("Urglit_SPELL_rangeX","LOCALS",1)
  //MoveViewObject(NearestEnemyOf(Myself),STANDARD)
END

// plus de sorts:corps ŗ corps
IF
 See(Nearestenemyof(Myself))
THEN
 RESPONSE #100
 Attack(Nearestenemyof(Myself)) 
END

