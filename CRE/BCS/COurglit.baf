// Urglite attaquťe
IF
  AttackedBy([GOODCUTOFF],DEFAULT)
  Allegiance(Myself,NEUTRAL)
THEN
  RESPONSE #100
    Shout(98)
    Enemy()

  // fin des lamtentations et Urglite repousse les intrus
  SetGlobal("Urglite_lamentations","COM021",1)
END

IF
 !See([PC])
THEN
  RESPONSE #100
  RandomWalk()
END


// Taguar est proche, elle entame le dialogue  ***********************************************************************************************************************
IF
 See("COTAGUAR")
 Global("URGLIT_TAGUAR","COM021",0) 
THEN
 RESPONSE #100
 SetGlobal("URGLIT_TAGUAR","COM021",1) 
 
 //CreateCreature("MINSC",[1200.460],6) 
 
 FaceObject([PC])
 StartDialogueNoSet([PC]) 
 Enemy()
 ActionOverride("COTAGUAR",Enemy())   
END


// Le groupe est proche, elle entame le dialogue  **********************************************************************************************************************
IF
 Range([PC],12)
 See([PC])
 Global("Urglite_lamentations","COM021",0)
 Global("URGLIT_TAGUAR","COM021",0) 
THEN
  RESPONSE #100
  
  // fin des lamtentations et Urglite repousse les intrus
  SetGlobal("Urglite_lamentations","COM021",1)

  ActionOverride("COURGLIT",StartDialogueNoSet([PC]))  
END

// Combat ***************************************************************************************************************************************************************
// Urglite va Ítre vaincue et Taguar est absent
IF
 HPPercentLT("COURGLIT",25)
 Global("COURGLIT_meurt","COM021",0)
THEN
 RESPONSE #100
 SetGlobal("COURGLIT_meurt","COM021",1)
 ClearAllActions()
  
  DisplayStringHead("COURGLIT",@21)  // Soyez tous maudits!
  ReallyForceSpell(Myself,WIZARD_GREATER_MALISON) 
  CreateVisualEffectObject("SPCLOUD1","COURGLIT")  
 
