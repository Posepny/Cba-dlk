// Ultime combat salle 8 + Kael allié + Boss mort
IF
 Global("KAEL_FIN","COM024",2)
 AreaCheck("COM024")
THEN
 RESPONSE #100
 SetGlobal("KAEL_FIN","GLOBAL",3)
 IncrementGlobal("NB_boss_dead","COM024",1)
 
 Setinterrupt(FALSE)
  DropInventory() 
  CreateVisualEffectObject("SPFDEATH",myself) 
  smallWait(10)
 Setinterrupt(TRUE)
 
 PlaySound("COBOO1")
 Deactivate(myself)
 Wait(1)

 ActionOverride(myself,DestroySelf())
END


