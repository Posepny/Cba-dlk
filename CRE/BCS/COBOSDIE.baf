// Epreuve salle 5 & mort Urglite
IF
 Die()
 AreaCheck("COM021")
 HasItem("RINGP11",myself) // Anneau air glacé
THEN
 RESPONSE #100 
 Setinterrupt(FALSE)
  DropInventory() 
  CreateVisualEffectObject("SPFDEATH","COURGLIT") 
  smallWait(10)
 Setinterrupt(TRUE)
 
 Deactivate(myself)
 Wait(1)
 
 ActionOverride(myself,DestroySelf())
END

// Epreuve salle 6 & mort Kael
IF
 Die()
 AreaCheck("COM022")
 HasItem("MISCP40",myself)
THEN
 RESPONSE #100
 
 Setinterrupt(FALSE)
  SetGlobal("Kael_vaincu","COM022",1)
 
  // larme de sang
  CreateItem("Miscp40",0,0,0)
  DropInventory() 
 
  //CreateVisualEffectObject("CODEATH",myself) 
  smallWait(10)
 Setinterrupt(TRUE)
 
 PlaySound("COBOO1") 
 Deactivate(myself)
 Createcreature("COKAEL2",[-1.-1],10)
 //Deactivate("COKAEL2")
 Wait(1)
 
 ActionOverride(myself,DestroySelf())
END


