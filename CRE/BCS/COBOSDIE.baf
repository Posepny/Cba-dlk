// Combat final: compteur boss mort pour ouvrir la grille + animation mort
IF
 Die()
 AreaCheck("COM024") 
THEN
 RESPONSE #100
 IncrementGlobal("NB_boss_dead","COM024",1) 
 CreateVisualEffectObject("CODEATH",myself) 
 smallWait(10)
 
 PlaySound("COBOO1")
 Deactivate(myself)
 Wait(1)
 
 ActionOverride(myself,DestroySelf())
END



// Epreuve salle 1 & mort démon: ajout larme de sang et coeur
IF
 Die()
 AreaCheck("COM018")
 HasItem("miscp35",myself)
THEN
 RESPONSE #100

 Setinterrupt(FALSE)
 CreateVisualEffectObject("CODEATH",myself) 
 smallWait(10)
 CreateItem("miscp35",0,0,0)
 DropInventory() 
 Setinterrupt(TRUE) 

 PlaySound("COBOO1")
 Deactivate(myself)
 Wait(1)
 ActionOverride(myself,DestroySelf())
END

