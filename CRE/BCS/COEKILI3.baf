// Le PLAYER suivi s'est téléporté sur l'autre carte: Ekilis ne suit plus le PNJ. Il en suivra un autre.
IF 
 AreaCheckObject("COM014","COEKILIS")
 Global("collier_TP_PLAYER","GLOBAL",1)
 Global("ekilis_follow","GLOBAL",1) 
 !Global("TimeTP","GLOBAL",0)   
THEN
 RESPONSE #100
 SetGlobal("ekilis_follow","GLOBAL",0) 
END

