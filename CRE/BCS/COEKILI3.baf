// Pas de combat: Ekilis suit le groupe ***************************************************************************************************************************************
// pas sur les cartes de téléportation: il suit le Charname
IF 
 !AreaCheckObject("COM014","COEKILIS")
 !AreaCheckObject("COM015","COEKILIS")
 Global("ekilis_alliance","GLOBAL",1)
 Global("ekilis_follow","GLOBAL",0)
 !See(Nearestenemyof(Myself))
 Detect(PLAYER1)
THEN
 RESPONSE #100
 SetGlobal("ekilis_follow","GLOBAL",1)
 //Createcreature("MINSC",[3600.1366],10)
END

IF
 !See(Nearestenemyof(Myself))
 Global("ekilis_follow","GLOBAL",1)
THEN
RESPONSE #100
 MoveToObjectFollow(PLAYER1)
 SmallWait(30)
END 

// sur les cartes de téléportation: il suit de PLAYER1 ŕ 6
IF 
 Global("ekilis_follow","GLOBAL",0)
 Global("ekilis_alliance","GLOBAL",1)
 !See(Nearestenemyof(Myself))
 Detect(PLAYER1)
 OR(2)
  AreaCheckObject("COM014","COEKILIS")
  AreaCheckObject("COM015","COEKILIS")
THEN
 RESPONSE #100
 SetGlobal("ekilis_follow","GLOBAL",1)
END

IF
 !See(Nearestenemyof(Myself))
 Global("ekilis_follow","GLOBAL",1)
THEN
RESPONSE #100
 MoveToObjectFollow(PLAYER1)
 SmallWait(30)
END 

