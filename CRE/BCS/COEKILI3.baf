// Ekilis est l'allié du groupe ********************************************************************************************************************************************
IF 
 Global("ekilis_alliance","GLOBAL",1)
 Global("ekil_alli_follow_init","GLOBAL",0)
THEN
 RESPONSE #100
 SetGlobal("ekil_alli_follow_init","GLOBAL",1)
 ChangeEnemyAlly("COEKILIS",ALLY)
 MakeGlobal()
 SetGlobal("ekilis_follow","GLOBAL",0)
END

