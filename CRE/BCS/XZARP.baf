// Pas de le groupe Ó l'origine de la save utilisķe. 120 000 XP pour remise Ó niveau
IF
	inparty(Myself)
	Global("XZARRecrut","GLOBAL",2)
THEN
	RESPONSE #100	
	SETGlobal("XZARRecrut","GLOBAL",3)
		
	AddXPObject(Myself,120000)
	ACTIONOVERRIDE("MONTARON",JOINPARTY()) 	
END

IF  
  inparty(Myself)
	!inparty("MONTARON") 
	Global("MONTARON","GLOBAL",3) // remerciķ par le charname, Xzar s'en va aussi.
THEN
	RESPONSE #100	
	leaveparty()
END