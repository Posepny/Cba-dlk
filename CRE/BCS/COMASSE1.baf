IF
 die()
THEN
 RESPONSE #100
 SetGlobal("massena_mort","Global",1)
 
  //Createcreature("MINSC",[3700.600],10)  
END

// 1iŤre recontre dans le Hall
IF
 Global("MASSENA_DLG","GLOBAL",0)
THEN
 RESPONSE #100
 SetGlobal("MASSENA_DLG","GLOBAL",1)
 StartDialogNoSet([PC]) 
END

// Massena est brulť
IF
 Global("ekilis_deactivate","Global",1)
THEN
 RESPONSE #100
 SetGlobal("ekilis_deactivate","Global",0)
 Deactivate("COMASSE1")
END

// Massena comprend que Bhaal communique avec le Charname: il stoppe le combat "Cessez le combat!"
IF
 Global("Puit_combat","GLOBAL",2) 
 See(PLAYER1)
 OR(2)
  Global("ekilis_mort","Global",1)
  Global("ekilis_alliance","Global",0)
THEN
 RESPONSE #100
 ChangeEnemyAlly("COMASSE2",NEUTRAL)
 SmallWait(10)
 
 PlaySound("EFF_E01")
 UnLock("DOOR0006")
 OpenDoor("DOOR0006")
 TriggerActivation("COT017C2",FALSE)
 SmallWait(10)
 
 ActionOverride("COMASSE2",StartDialogueNoSet(PLAYER1))
END
  
// Cutscene Massena devant le puit
IF
 Global("Puit_combat","GLOBAL",3)
THEN
 RESPONSE #100
 
 ClearAllActions()
 smallwait(20)
 StartCutSceneMode()
 Wait(1) 
 SetInterrupt(FALSE)
  StartCutScene("CSMASSE2")  
 SetInterrupt(FALSE)
END  

// Massena dťcouvre que le Charname est l'enfant de Bhaal
IF
 Global("Puit_combat","GLOBAL",4)
THEN
 RESPONSE #100
 ActionOverride("COMASSE2",StartDialogueNoSet(PLAYER1))
END

