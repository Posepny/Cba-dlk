// Le groupe revient victorieux des ťpreuves: Massena l'attend ************************************************************************************************************
IF
 Global("Bhaal_epreuves","GLOBAL",3)
THEN
 RESPONSE #100
 SetGlobal("Bhaal_epreuves","GLOBAL",4)
  
 ActionOverride("COMASSE2",SetDialogue("COMASSE4")) 
 ActionOverride("COMASSE2",StartDialogueNoSet(PLAYER1))
END

// Le charname accepte d'Ítre le Champion: dťmarrage de la priŤre.
IF
  Global("Bhaal_allie","GLOBAL",1)
  Global("Masque_M_priere","GLOBAL",0) 
THEN
 RESPONSE #100

 // Massena se dťplace
 MoveToPoint([3707.636])
 Wait(2)
 
 // Dťbut priŤre
 Createcreature("COBHAAL",[3720.720],10)
 SetGlobal("Masque_M_priere","GLOBAL",1) 
END

// QuÍte ťpreuve de Bhaal rťalisťe: alliť ŗ Bhaal
IF
  Global("Bhaal_allie","GLOBAL",1)
  Global("Q_bhaal_epreuve","COM017",0) 
THEN
 RESPONSE #100
 SetGlobal("Q_bhaal_epreuve","COM017",1)
 
  // mise ŗ jour journal
  EraseJournalEntry(@200)
  EraseJournalEntry(@201)
  AddJournalEntry(@202,QUEST_DONE)
  AddexperienceParty(2000) 
END

// QuÍte ťpreuve de Bhaal rťalisťe: pas alliť ŗ Bhaal
IF
  Global("Bhaal_allie","GLOBAL",2)
  Global("Q_bhaal_epreuve","COM017",0) 
THEN
 RESPONSE #100
 SetGlobal("Q_bhaal_epreuve","COM017",1)
 
  // mise ŗ jour journal
  EraseJournalEntry(@200)
  EraseJournalEntry(@201)
  AddJournalEntry(@203,QUEST_DONE)
  AddexperienceParty(2000) 
END

// QuÍte ťpreuve de Bhaal rťalisťe: attaque pendant la priŤre (trahison)
IF
  Global("priere_trahison","GLOBAL",1) 
THEN
 RESPONSE #100
 SetGlobal("priere_trahison","GLOBAL",2) 
 
  // mise ŗ jour journal
  EraseJournalEntry(@200)
  EraseJournalEntry(@201)
  EraseJournalEntry(@202)
  AddJournalEntry(@203,QUEST_DONE)  
END

 


