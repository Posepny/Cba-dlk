// Baguette 1 de commandement **********************************************************************************************************************************
IF
  Global("Command_WANP01","LOCALS",1)
  See(Nearestenemyof(Myself))  
THEN
  RESPONSE #100
  AttackReevaluate(Nearestenemyof(Myself),30)
END

IF
  Global("Command_WANP01","LOCALS",1)
  HasItem("WANP01",PLAYER1)
  !See(Nearestenemyof(Myself))  
THEN
  RESPONSE #100
  MoveToObjectFollow(PLAYER1)
END

IF
  Global("Command_WANP01","LOCALS",1)
  HasItem("WANP01",PLAYER2)
  !See(Nearestenemyof(Myself))  
THEN
  RESPONSE #100
  MoveToObjectFollow(PLAYER2)
END

