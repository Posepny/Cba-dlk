  MoveToObjectFollow(PLAYER6)
END

IF
  Global("Command_WANP01","LOCALS",1)
  OR(6)
   !HasItem("WANP01",PLAYER1)  
   !HasItem("WANP01",PLAYER2)
   !HasItem("WANP01",PLAYER3)
   !HasItem("WANP01",PLAYER4)
   !HasItem("WANP01",PLAYER5)
   !HasItem("WANP01",PLAYER6)
THEN
  RESPONSE #100
  RandomWalk()
END

