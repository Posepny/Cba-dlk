/*  Mod Protecteur de Baldur **********************************************************************************************************************************************
// Livraison tęte du marchand de Davos
IF
 Global("MAGASINIER_DAVOS_TETE","Global",1)
 AreaCheckObject("AR7216","PROTAGONIST")
THEN
 RESPONSE #100
 SetGlobal("MAGASINIER_DAVOS_TETE","Global",2) 
  
 // Changement de dialogue
 ActionOverride("WAITER",SetDialog("TETEP"))
 ActionOverride("WAITER",Dialogue(PROTAGONIST))
END

IF
 Global("LIVRAISON_TETE","Global",1)
 Global("MAGASINIER_DAVOS_TETE","Global",2) 
THEN
 RESPONSE #100
 SetGlobal("MAGASINIER_DAVOS_TETE","Global",3) 
 
 GiveItemCreate("MISCP18",PROTAGONIST,0,0,0) 
 continue()
END

// Livraison tęte de Davos
IF
 Global("DAVOS_TETE","Global",1) 
THEN
 RESPONSE #100
 SetGlobal("DAVOS_TETE","Global",2) 
 
 // Changement de dialogue
 ActionOverride("WAITER",SetDialog("TETEP"))
 ActionOverride("WAITER",Dialogue(PROTAGONIST))
END

IF
 Global("LIVRAISON_TETE","Global",1)
 Global("DAVOS_TETE","Global",2) 
THEN
 RESPONSE #100
 SetGlobal("DAVOS_TETE","Global",3) 
 
 GiveItemCreate("MISCP19",PROTAGONIST,0,0,0)
 continue()
END

// Livraison tęte de Irma
IF
 Global("IRMA_TETE","Global",1) 
THEN
 RESPONSE #100
 SetGlobal("IRMA_TETE","Global",2) 
 
 // Changement de dialogue
 ActionOverride("WAITER",SetDialog("TETEP"))
 ActionOverride("WAITER",Dialogue(PROTAGONIST))
END

IF
 Global("LIVRAISON_TETE","Global",1)
 Global("IRMA_TETE","Global",2) 
THEN
 RESPONSE #100
 SetGlobal("IRMA_TETE","Global",3) 
 
 GiveItemCreate("MISCP20",PROTAGONIST,0,0,0) 
 continue()
END

// Réinit livraison tęte
IF
 Global("LIVRAISON_TETE","Global",1) 
THEN
 RESPONSE #100
 SetGlobal("LIVRAISON_TETE","Global",0)
 
 DisplayString("WAITER",@3) 
 ActionOverride("WAITER",SetDialog("WAITER"))
END

// Quęte recrutement Compagnon pour le Protecteur: si au moins deux compagnons: quęte réussie
IF
 Global("quete_equipe_protecteur","Global",0)
 NumInPartyGT(3)
THEN
 RESPONSE #100
 SetGlobal("quete_equipe_protecteur","Global",1)
 
 
 SetGlobal("Msg_mission_nettoyage","Global",1) // Activation du messager des ducs pour la mission 
 // Journal quęte résolue
 AddexperienceParty(600)
 EraseJournalEntry(@1)
 AddJournalEntry(@2,QUEST_DONE) 
END
*/