
// Mod Champion de Bhaal (partie du mod Protecteur de Baldur sans le mod principal) ***********************************************************************************************************************************************
// TextScreen d'intro
IF 
 Global("Protecteur_baldur","GLOBAL",1)
 Global("Mod_CDB","GLOBAL",1)
 Global("intro_TS","AR7216",0)
THEN 
 RESPONSE #100
 SetGlobal("intro_TS","AR7216",1)
 
 FadeTOColor([30.0],0)
 
 // Passage chapitre 9 BG1: initialisation de la transition BG1 -> Mod Protecteur de Baldur
 SetGlobal("Chapter","GLOBAL",9)
 TextScreen("COTSCDB")   
 DisplayString("Veuillez patienter")
 
 Global("Recrut_fin","AR7216",0)
END


// Impossibilité de quitter de l'auberge dans le cadre du Mod
IF
 Global("Mod_CDB","GLOBAL",1)
 Global("entree_fermee","AR7216",0)
THEN
 RESPONSE #100
 SetGlobal("entree_fermee","AR7216",1)
 
 TriggerActivation("Door7200",FALSE)   
END


// Suppression du groupe au bar remplacé par les nouveaux pnj ŕ recruter ************************************************************************************
IF
 Global("AR7216_1","AR7216",0)
 Global("Protecteur_baldur","GLOBAL",1)
THEN
 RESPONSE #100
 SetGlobal("AR7216_1","AR7216",1)


 ActionOverride("Gorpel",destroyself())
 ActionOverride("Farluck",destroyself())
 ActionOverride("Turpin",destroyself())
 ActionOverride("Nelik",destroyself())
 ActionOverride("BART12",destroyself())

 CreateCreature("COBARNI",[620.620],6)  
 CreateCreature("geoffro",[679.676],6)   
 CreateCreature("alinea",[657.712],6)    
 CreateCreature("OSWALD",[707.636],6) 
 CreateCreature("FLAMHC",[690.485],11)
END

// Quęte barni: condamner la cave et reprise de la clé.
IF
 Global("Barni_quete","GLOBAL",2)  
THEN
 RESPONSE #100
 SetGlobal("Barni_quete","GLOBAL",5) 
 
 TakePartyItem("Miscp61") 
END

