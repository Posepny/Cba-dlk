BEGIN ~COTANAR1~

// Proposition Cambion ťpťe
IF ~Global("Quete_cambion_epee","COM018",0)~ THEN BEGIN 0

  SAY @1 /* ~Apportes moi l'ťpťe du Cambion et je te donnerai un prťsent digne d'un sang de Bhaal.~ */
  IF ~~ THEN 
    REPLY @2 /* ~Ca ne m'intťresse pas.~ */
    DO ~SetGlobal("Quete_cambion_epee","COM018",1)
        SetGlobal("Quete_cambion_epee_OK","COM018",1)~
    GOTO 1

  // QuÍte coeur dťmon Active
  IF ~Global("Quete_demon_coeur","COM018",1)
      Global("Com018_Cambion_mort","COM018",0)~ THEN     
    REPLY @7 /* ~Dťmon, le Cambion a besoin de ton coeur et je suis venu te l'arracher!~ */
    DO ~SetGlobal("Quete_cambion_epee","COM018",1)~    
    GOTO 6

  IF ~!HasItem("SW1H02",LastTalkedToBy(Myself))~ THEN 
    REPLY @4 /* ~Ton prťsent a intťrÍt d'Ítre ŗ la hauteur de mes attentes.~ */   
    DO ~SetGlobal("Quete_cambion_epee","COM018",1)
    SetGlobal("Quete_cambion_epee_OK","COM018",1)~ 
    EXIT

  IF ~HasItem("SW1H02",LastTalkedToBy(Myself))~ THEN     
    REPLY @5 /* ~Est-ce ceci que tu dťsires (vous lui montrez l'ťpťe du Cambion)?~ */
    DO ~SetGlobal("Quete_cambion_epee","COM018",1)~
    GOTO 3

END

IF ~~ THEN BEGIN 1

  SAY @6 /* ~Hors de ma vue!~ */
  IF ~~ THEN 
    EXIT

END

// QuÍte ťpťe Cambion rťsolue
IF ~Global("Quete_cambion_epee","COM018",1)
    HasItem("SW1H02",LastTalkedToBy(Myself))~ THEN BEGIN 3

  SAY @9 /* ~Une magnifique ťpťe... J'espŤre qu'il a souffert. Hors de ma vue maintenant.~ */
  IF ~~ THEN        
    REPLY @11 /* ~Ne rien dire.~ */
    DO ~SetGlobal("Quete_cambion_epee","COM018",2)~
    EXIT
    
  IF ~~ THEN 
    REPLY @10 /* ~Et mon prťsent?~ */
    DO ~SetGlobal("Quete_cambion_epee","COM018",3)~
    GOTO 4

END

IF ~~ THEN BEGIN 4

  SAY @12 /* ~Je te laisse en vie. J'ai ŗ faire, Hors de ma vue! ~ */
  IF ~~ THEN 
    DO ~TakePartyItem("MISC6M")~    
    EXIT

END

// QuÍte ťpťe Cambion active
IF ~Global("Quete_cambion_epee","COM018",1)
    !HasItem("SW1H02",LastTalkedToBy(Myself))~ THEN BEGIN 5

  SAY @13 /* ~Tu n'as pas l'ťpťe. Tu me fais perdre mon temps!~ */
  
  // QuÍte coeur dťmon Active
  IF ~Global("Quete_demon_coeur","COM018",1)~ THEN 
    REPLY @14 /* ~J'ai parlť au Cambion. Je suis venu chercher ton coeur.~ */    
    GOTO 6
    
    IF ~~ THEN 
    REPLY @16 /* ~Ne rien rťpondre.~*/
    EXIT
    
END

IF ~~ THEN BEGIN 6

  SAY @15 /* ~Ce serpent a ralliť le sang de Bhaal ŗ sa cause!~ */
  IF ~~ THEN 
    // Combat dťmon
    DO~ChangeAIScript("TANARI",OVERRIDE)
       Enemy()~ 
    EXIT
    
END


