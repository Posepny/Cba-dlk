// info signalant qu'une corde est prťsente. Elle permettrait de remonter au niveau supp.
IF
  Entered([PC]) 
  InPartySlot(LastTrigger,0) // Player1 
THEN
  RESPONSE #100
  
  Createcreature("COCORD",[480.359],10)
  ActionOverride("COCORD",StartDialog("COBCOR1",PLAYER1)
END

