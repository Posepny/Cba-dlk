// La fontaine soigne Kael ‡ distance
IF 
  Global("KAEL_blesse","COM022",1) 
  !Dead("COKAEL")
THEN
 RESPONSE #100 
 SetGlobal("KAEL_blesse","COM022",0) 
 
 TriggerActivation("COT022F",FALSE) 
 ForceSpellRes("COCUREF1","COKAEL") 
 DisplayStringHead("COKAEL",@50)  
 
 RESPONSE #100 
 SetGlobal("KAEL_blesse","COM022",0) 
 
 TriggerActivation("COT022F",FALSE) 
 ForceSpellRes("COCUREF1","COKAEL") 
 DisplayStringHead("COKAEL",@51)  
 
 RESPONSE #100 
 SetGlobal("KAEL_blesse","COM022",0) 
 
 TriggerActivation("COT022F",FALSE) 
 ForceSpellRes("COCUREF1","COKAEL") 
 DisplayStringHead("COKAEL",@52)   

END

