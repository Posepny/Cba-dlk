// au 1ier passage du Charname le TS se dÈclenche.
IF
 Clicked([0])
 Range(PLAYER1,6)
 Global("COM022_TS","GLOBAL",0)
THEN
 RESPONSE #100
 SetGlobal("COM022_TS","GLOBAL",1) 
 SetGlobal("COM022_grille","GLOBAL",1)

 //PlaySound("COBOO1")
 //PlaySound("COBOO1") // Temoin

 TextScreen("COTS008")
 ActionOverride(PLAYER1,LeaveAreaLUA("COM023","",[1643.802],10)) 
END

