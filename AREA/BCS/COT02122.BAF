// Gestion arrivÈe des PC ***********************************************************************************************************************************************
// Le but est de savoir quels sont les PLAYERS qui vont devoir se tÈlÈporter
IF
 AreaCheckObject("COM021",PLAYER1)
 Global("com021_P1","GLOBAL",0)
THEN
 RESPONSE #100
 SetGlobal("com021_P1","GLOBAL",1)
END

