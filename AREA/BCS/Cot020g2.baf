// Ouverture de la grille grâce à la pierre
IF
  Isoverme(PLAYER1)
  HasItem("MISCP59",PLAYER1)
  OpenState("GRILLE2",FALSE) 
THEN
  RESPONSE #100
  
  // ouverture de l'accès à la salle aux damiers
  Unlock("GRILLE2")
  OpenDoor("GRILLE2")
  TriggerActivation("COM019",TRUE)
  SetGlobal("Acces_COM019","GLOBAL",2)
  
  //Createcreature("MINSC",[1166.110],10)
END