// le PS doit ętre ouvert si au moins un actionneur actif
IF
 OpenState("PS5",FALSE)
 GlobalTimerExpired("PS5_OUVERT","COM021")
 OR(2) 
  Global("Action1_PS5","COM021",1)
  Global("Action2_PS5","COM021",1)
THEN
 RESPONSE #100  

 PlaySound("GAM_21")
 
 OpenDoor("PS5")
 PlaySound("AMB_D04A")
   
 // Relance vérification 
 SetGlobalTimer("PS5_OUVERT","COM021",2) 
END

// le PS reste ouvert si au moins un actionneur actif
IF
 OpenState("PS5",TRUE)
 GlobalTimerExpired("PS5_OUVERT","COM021")
 OR(2) 
  Global("Action1_PS5","COM021",1)
  Global("Action2_PS5","COM021",1)
THEN
 RESPONSE #100  

 PlaySound("GAM_21")
 
 // Relance vérification 
 SetGlobalTimer("PS5_OUVERT","COM021",2) 
END

// le PS est fermé si aucun actionneur actif
IF
  OpenState("PS5",TRUE)
  GlobalTimerExpired("PS5_OUVERT","COM021")
  Global("Action1_PS5","COM021",0)
  Global("Action2_PS5","COM021",0)
THEN
 RESPONSE #100  

 CloseDoor("PS5")
 PlaySound("AMB_D04A")
   
 // Relance vérification 
 SetGlobalTimer("PS5_OUVERT","COM021",2) 
END




