// au 1ier passage du Charname le TS se dÈclenche.
IF
 Clicked([0])
 Range(PLAYER1,6)
 Global("COM022_TS","GLOBAL",0)
THEN
 RESPONSE #100
 SetGlobal("COM022_TS","GLOBAL",1) // Fin TS
 SetGlobal("COM022_grille","GLOBAL",1)
 
 //PlaySound("COBOO1") // Temoin
 
 TextScreen("COTS008")
 ActionOverride(PLAYER1,LeaveAreaLUA("COM022","",[2515.585],5)) 
 Continue()
END

