// DÈpart TP vers un niveau alÈatoire
IF
 Global("com017_P1","GLOBAL",1)
THEN
  RESPONSE #100
  SetGlobal("com017_P1","GLOBAL",2)
  SetInterrupt(FALSE)  
   Wait(1)
   ActionOverride(PLAYER1,LeaveAreaLUA("COM018","",[870.1240],10))
   ActionOverride(PLAYER1,ChangeAIScript("",RACE)) 
  SetInterrupt(TRUE)  
END

