// si le pnj possčde le collier de perles de bhaal alors téléportation au niveau 1B
IF
  Isoverme(PLAYER1)
  HasItem("AMUP02",PLAYER1)
  Global("TimeTP","GLOBAL",0)
THEN
  RESPONSE #100
  SetGlobal("TimeTP","GLOBAL",1)
  SetGlobal("TimeTP_EKI","GLOBAL",1)

/*
  SetGlobal("CIBLE_TP","GLOBAL",1) 
//createcreature("MINSC",[750.500],10) 
  SetInterrupt(FALSE)  
  PlaySound("CAS_P07")
  ForceSpellRES("com014TP",PLAYER1)
  SetInterrupt(TRUE)   
*/ 

  SetInterrupt(FALSE)
   ForceSpellRES("COTPEND",PLAYER1) 
   PlaySound("CAS_P07")
   Wait(1)
   ActionOverride(Player1,LeaveAreaLUA("COM015","",[3000.1784],10))  
  SetInterrupt(TRUE)
END

