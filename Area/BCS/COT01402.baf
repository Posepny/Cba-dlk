IF
  //Entered([0]) 
  IsOverMe([ANYTHING])
  Global("COT01402","GLOBAL",0)  
  Global("Crane_place","GLOBAL",0)
THEN
  RESPONSE #100
  ForceSpellPoint([2700.2580],WIZARD_ICE_STORM)
  SetGlobal("COT01402","GLOBAL",1)
END

IF
 Global("COT01402","GLOBAL",1)
THEN
 RESPONSE #100
 WAIT(100)
 SetGlobal("COT01402","GLOBAL",0)
END