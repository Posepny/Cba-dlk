// Trop loin
IF
  Clicked([ANYONE])
  !Range(LastTrigger,8)
THEN
  RESPONSE #100
  DisplayStringHead(LastTrigger,@3)  
END

// assez pr鋊 
IF
  Clicked([ANYONE])
  Range(LastTrigger,8)
  Global("Corde_lancee1","GLOBAL",1)
THEN
  RESPONSE #100
  Createcreature("COCORD",[165.611],10)
  ActionOverride(LastTrigger,StartDialog("COBCORD",LastTrigger)) 
END

