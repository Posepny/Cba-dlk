IF
  Entered([0]) 
  Global("COT01403","GLOBAL",0)  
  Global("Crane_place","GLOBAL",0)
THEN
  RESPONSE #100
  ForceSpell(Lasttrigger,WIZARD_AGANNAZAR_SCORCHER)
  SetGlobal("COT01403","GLOBAL",1)
END

IF
 Global("COT01403","GLOBAL",1)
THEN
 RESPONSE #100
 WAIT(100)
 SetGlobal("COT01403","GLOBAL",0)
END