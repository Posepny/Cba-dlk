IF
  OnCreation()
  Global("COM014_INIT","GLOBAL",0)
THEN
  RESPONSE #100
    SetGlobal("COM014_INIT","GLOBAL",1)
    CreateCreature("COEKILIS",[3636.1366],1)
    
    CreateCreature("COMINAU1",[1100.490],10)
    CreateCreature("COMINAU1",[1166.529],10)
    CreateCreature("COMINAU2",[1166.529],10)
    CreateCreature("COMINAU2",[1166.529],10)
    CreateCreature("COMINAU3",[1166.529],10)
    CreateCreature("ELEMEP01",[3200.1070],10)
    CreateCreature("ELEMEP02",[3320.1170],10)
    CreateCreature("ELEMEP03",[3265.1180],10)
    CreateCreature("ELEMEP08",[3600.1000],10)
    CreateCreature("ELEMEP05",[3975.1100],10)    
        
    CreateCreature("BAT_IN",[1260.2035],10)
    CreateCreature("BAT_IN",[1400.2056],10)
    CreateCreature("BAT_IN",[2500.650],10)
    CreateCreature("BAT_IN",[2550.670],10)
    CreateCreature("BAT_IN",[1450.800],10)
    CreateCreature("BAT_IN",[1470.820],10)    
    
    ContainerEnable("CACHE01",FALSE)
    ContainerEnable("CACHE02",FALSE)
    ContainerEnable("CACHE03",FALSE)
END

