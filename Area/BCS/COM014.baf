 Oncreation()
THEN
 RESPONSE #100
 
 // Ekilis endormis
 Createcreature("COEKILIS",[3600.1366],10)
END

 // Animation sphčre de magie
IF
 Global("STASE_EKILIS","GLOBAL",0)
THEN
 RESPONSE #100
 SetGlobal("STASE_EKILIS","GLOBAL",1)
 
 actionoverride("COEKILIS",ReallyForceSpell("COEKILIS",CLERIC_SANCTUARY))
 wait(10)  
END

