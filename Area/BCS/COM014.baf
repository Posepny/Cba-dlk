// gestion de la grille en fonction de la position du levier ***************************************************************************************************************
IF
 OpenState("LEVIER01",TRUE)
 Global("levier01","GLOBAL",1)
THEN
 RESPONSE #100
 SetGlobal("levier01","GLOBAL",0)
 
 OpenDoor("HERSE01")
END

IF
 OpenState("LEVIER01",FALSE)
 Global("levier01","GLOBAL",0)
THEN
 RESPONSE #100
 SetGlobal("levier01","GLOBAL",1)
 
 CloseDoor("HERSE01")  
END

// Le groupe prend les restes de Massena dans son équipement: le collier de massena apparait dans l'équipement *************************************************************
IF
 HasItem("Skelp01",PLAYER1)
 Global("collier_massena_init","GLOBAL",0)
THEN
 RESPONSE #100
 SetGlobal("collier_massena_init","GLOBAL",1)
 SetGlobal("collier_TP_PLAYER","GLOBAL",1)
 ActionOverride(PLAYER1,CreateItem("AMUP02",0,0,0)) 
END

IF
 HasItem("Skelp01",PLAYER2)
 Global("collier_massena_init","GLOBAL",0)
THEN
 RESPONSE #100
