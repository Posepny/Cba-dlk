// Gestion de l'accčs ŕ la cache au potion d'Ekilis
IF
  OnCreation()				// La premičre fois que l'on entre dans la carte.
  Global("CACHE02","COM014",0)
THEN
  RESPONSE #100
  SetGlobal("CACHE02","COM014",1)	
  ContainerEnable("CACHE02",FALSE)	
  Continue()
END

