// cache ŕ bijoux d'Ekilis découverte
IF
  OpenState("CACHE",TRUE)		
  Global("CACHE01","COM014",0)
THEN
  RESPONSE #100
  SetGlobal("CACHE01","COM014",1)	
  
  ContainerEnable("Cache01",TRUE)	// container accessible si le PS est découvert
END

