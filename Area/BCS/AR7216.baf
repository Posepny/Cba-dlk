// Réinit livraison tęte
IF
 Global("LIVRAISON_TETE","Global",1) 
THEN
 RESPONSE #100
 SetGlobal("LIVRAISON_TETE","Global",0)
 
 DisplayString("WAITER",@3) 
 ActionOverride("WAITER",SetDialog("WAITER"))
END

// Quęte recrutement Compagnon pour le Protecteur: si au moins deux compagnons: quęte réussie
IF
 Global("quete_equipe_protecteur","Global",0)
 NumInPartyGT(3)
THEN
 RESPONSE #100
 SetGlobal("quete_equipe_protecteur","Global",1)
 
 
 SetGlobal("Msg_mission_nettoyage","Global",1) // Activation du messager des ducs pour la mission 
 // Journal quęte résolue
 AddexperienceParty(600)
 EraseJournalEntry(@1)
 AddJournalEntry(@2,QUEST_DONE) 
END
*/