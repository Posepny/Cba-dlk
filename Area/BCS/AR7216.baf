/*  Mod Protecteur de Baldur **********************************************************************************************************************************************
// Livraison tęte du marchand de Davos
IF
 Global("MAGASINIER_DAVOS_TETE","Global",1)
 AreaCheckObject("AR7216","PROTAGONIST")
THEN
 RESPONSE #100
 SetGlobal("MAGASINIER_DAVOS_TETE","Global",2) 
  
 // Changement de dialogue
 ActionOverride("WAITER",SetDialog("TETEP"))
 ActionOverride("WAITER",Dialogue(PROTAGONIST))
END

IF
 Global("LIVRAISON_TETE","Global",1)
 Global("MAGASINIER_DAVOS_TETE","Global",2) 
THEN
 RESPONSE #100
 SetGlobal("MAGASINIER_DAVOS_TETE","Global",3) 
 
 GiveItemCreate("MISCP18",PROTAGONIST,0,0,0) 
 continue()
END

// Livraison tęte de Davos
IF
 Global("DAVOS_TETE","Global",1) 
THEN
 RESPONSE #100
 SetGlobal("DAVOS_TETE","Global",2) 
 
 // Changement de dialogue
 ActionOverride("WAITER",SetDialog("TETEP"))
 ActionOverride("WAITER",Dialogue(PROTAGONIST))
END

IF
 Global("LIVRAISON_TETE","Global",1)
 Global("DAVOS_TETE","Global",2) 
THEN
 RESPONSE #100
 SetGlobal("DAVOS_TETE","Global",3) 
 
 GiveItemCreate("MISCP19",PROTAGONIST,0,0,0)
 continue()
END

