IF
  //Entered([0]) 
  IsOverMe([ANYTHING])
  Global("COT01405","GLOBAL",0)  
  //Global("Crane_place","GLOBAL",0)
THEN
  RESPONSE #100
  ForceSpell(Lasttrigger,TRAP_HOLD_PERSON)
  SetGlobal("COT01405","GLOBAL",1)
END

IF
 Global("COT01405","GLOBAL",1)
THEN
 RESPONSE #100
 WAIT(200)
 SetGlobal("COT01405","GLOBAL",0)
END


