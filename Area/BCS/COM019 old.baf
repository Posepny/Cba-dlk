IF
  Global("MINSC","COM019",0)
THEN
  RESPONSE #100 
  SetGlobal("MINSC","COM019",1)
  CreateCreature("COSTATE",[574.685],6)
END


// Islendra n'a pas le droit de monter ŕ l'étage. ******************************************************************************************************************
IF
 AreaCheckObject("COM019","COISLEN") 
THEN 
 RESPONSE #100
 DisplaystringHead("COISLEN",@3)
 Deactivate("COISLEN")
 ActionOverride("COISLEN",destroyself())
 SetGlobal("COM020_COISLEN_DESC","GLOBAL",1)
 
 Createcreature("MINSC",[574.685],6)  
END


// Accčs au sous_sol KO *********************************************************************************************************************************************
IF
 Global("Acces_COM019","GLOBAL",1)
THEN
 RESPONSE #100
 SetGlobal("Acces_COM019","GLOBAL",0)
  
 TriggerActivation("COM020",FALSE)
 TriggerActivation("COM020_KO",TRUE)
END

// Accčs au sous_sol OK
IF
 Global("Acces_COM019","GLOBAL",2)
THEN
 RESPONSE #100
 SetGlobal("Acces_COM019","GLOBAL",0)
  
 TriggerActivation("COM020",TRUE)
 TriggerActivation("COM020_KO",FALSE) 
END



// Pierre orange et chaude déposée dans l'effigie 3: ouverture Salle porte Kael ******************************************************************************************
IF
  OpenState("GRILLE2",FALSE)
  Contains("MISCP30","EFFIGIE03")
THEN
  RESPONSE #100  
  
  Unlock("GRILLE2")  
  OpenDoor("GRILLE2")   
  
  continue() 
END

// Pierre non déposée dans l'effigie 3
IF
  OpenState("GRILLE2",TRUE)
  !Contains("MISCP30","EFFIGIE03")
THEN
  RESPONSE #100  
  
  CloseDoor("GRILLE2")
  Lock("GRILLE2")
  
  continue() 
END


// Pierre bleu étoile déposée dans l'effigie 4: arręt pičges élémentaux ***************************************************************************************************
IF
  Contains("MISCP34","EFFIGIE04")
THEN
  RESPONSE #100  
  TriggerActivation("COT0198A",FALSE)  
  TriggerActivation("COT0198B",FALSE)  
  TriggerActivation("COT0198C",FALSE)    
  TriggerActivation("COT0198D",FALSE)  
  
  continue() 
END

// Pierre non déposée dans l'effigie 4
IF
  !Contains("MISCP34","EFFIGIE04")
THEN
  RESPONSE #100  
  TriggerActivation("COT0198A",TRUE)  
  TriggerActivation("COT0198B",TRUE)  
  TriggerActivation("COT0198C",TRUE)    
  TriggerActivation("COT0198D",TRUE)  
  
  continue() 
END


// Pierre rouge sombre déposée dans l'effigie 7: ouverture salle des morts ************************************************************************************************
IF
  OpenState("GRILLE1",FALSE)
  Contains("MISCP33","EFFIGIE07")
THEN
  RESPONSE #100  
  Unlock("GRILLE1")  
  OpenDoor("GRILLE1")   
  
  continue() 
END

// Pierre non déposée dans l'effigie 7
IF  
  OpenState("GRILLE1",TRUE)
  !Contains("MISCP33","EFFIGIE07")
THEN
  RESPONSE #100  
  CloseDoor("GRILLE1")
  Lock("GRILLE1")
  
  continue() 
END


// Pierre grenat déposée dans l'effigie 8: arręt pičge crâne et rűnes ******************************************************************************************************
IF
  Contains("MISCP28","EFFIGIE08")
THEN
  RESPONSE #100  
  TriggerActivation("COT0196A",FALSE)  
  TriggerActivation("COT0196B",FALSE)  
  TriggerActivation("COT0196C",FALSE)  
  
  TriggerActivation("COT0197A",FALSE)  
  TriggerActivation("COT0197B",FALSE)  
  TriggerActivation("COT0197C",FALSE)    
  TriggerActivation("COT0197D",FALSE)  
  
  continue()  
END

// Pierre non déposée dans l'effigie 8
IF
  //Global("effigie08","COM019",1)
  !Contains("MISCP28","EFFIGIE08")
THEN
  RESPONSE #100  
  TriggerActivation("COT0196A",TRUE)  
  TriggerActivation("COT0196B",TRUE)  
  TriggerActivation("COT0196C",TRUE)  
  
  TriggerActivation("COT0197A",TRUE)  
  TriggerActivation("COT0197B",TRUE)  
  TriggerActivation("COT0197C",TRUE)    
  TriggerActivation("COT0197D",TRUE)  
  
  continue() 
END


// Elvina est en colčre. Galik apparait ************************************************************************************************************************************
IF
 Global("statue_elvina_Galik","COM019",1)
THEN
 RESPONSE #100
 SetGlobal("statue_elvina_Galik","COM019",2)
 //CreateCreature("MINSC",[574.685],6)
 CreateCreature("COGalik",[1065.365],10)
 CreateVisualEffectObject("gwshair7","COGalik")
END
































