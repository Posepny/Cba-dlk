// Téléportation duel Islendra ****************************************************************************************************************************************************
IF
 Global("COM020_PNJ_capture","GLOBAL",1)
 AreaCheckObject("COM019","COISLEN") 
THEN
 RESPONSE #100
 SetGlobal("COM020_PNJ_capture","GLOBAL",2)
 
 
