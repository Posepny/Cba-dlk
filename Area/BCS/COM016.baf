// Le cadavre n'est plus dans l'équipement du groupe: le collier disparait.
IF
 !PartyHasItem("Skelp01")
 PartyHasItem("AMUP02") 
 Global("collier_massena_init","GLOBAL",1)
THEN
 RESPONSE #100
 SetGlobal("collier_massena_init","GLOBAL",0)
 TakePartyItem("AMUP02")
 /*
 wait(3)
 Actionoverride("COMASSE1",TakePartyItem("AMUP02"))
 */
END




// Ekilis en vie et le cadavre a été déposé dans le sarcophage: Massena est faché *********************************************************************
IF 
 Global("MF_temple_bhaal","GLOBAL",1)
THEN
 RESPONSE #100 
 SetGlobal("MF_temple_bhaal","GLOBAL",2)
 Deactivate("COMASSE1")
 
 Createcreature("MISTPO01",[316.289],10) 
 SmallWait(10)
 GiveItemCreate("COKEY01","MISTPO01",1,1,0) 
 
 Createcreature("GIBBER_P",[314.516],10) 
 Createcreature("GIBBER_P",[314.500],10) 
 Createcreature("GIBBER_P",[300.516],10) 
END
