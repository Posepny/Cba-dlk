IF
  //Entered([0]) 
  IsOverMe([ANYTHING])
  Global("COT01414","GLOBAL",0)  
  //Global("Crane_place","GLOBAL",0)
THEN
  RESPONSE #100
  ForceSpell(Lasttrigger,WIZARD_HORROR)
  SetGlobal("COT01414","GLOBAL",1)
END

IF
 Global("COT01414","GLOBAL",1)
THEN
 RESPONSE #100
 WAIT(100)
 SetGlobal("COT01414","GLOBAL",0)
END
