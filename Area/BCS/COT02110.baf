// PS fermť
IF
 GlobalTimerExpired("GRILLE2_OUVERT","COM021")
 OpenState("GRILLE2",TRUE)
 Entered([0])
THEN
 RESPONSE #50  
 SetGlobal("GRILLE2_ferme","COM021",1) 
   
 // Relance vťrification 
 SetGlobalTimer("GRILLE2_OUVERT","COM021",2) 
END

