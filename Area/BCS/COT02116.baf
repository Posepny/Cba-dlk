// personne sur la zone: la porte doit õtre fermÕe
IF
 !Range([0],2)
 Global("Action1_PS5","COM021",1)
THEN
 RESPONSE #100  
 SetGlobal("Action1_PS5","COM021",0)
END

// un PLAYER ou une crÕature sur la zone: la porte doit õtre ouverte
IF
 Range([0],2)
 Global("Action1_PS5","COM021",0)
THEN
 RESPONSE #100  
 SetGlobal("Action1_PS5","COM021",1)
END







