IF
 GlobaltimerExpired("MSG_Sphinx","COM023")
 NumInParty(6)
 AreaCheckObject("COM023",PLAYER1)
 AreaCheckObject("COM023",PLAYER2)
 AreaCheckObject("COM023",PLAYER3)
 AreaCheckObject("COM023",PLAYER4)
 AreaCheckObject("COM023",PLAYER5)
 AreaCheckObject("COM023",PLAYER6)
 Global("gpe_complet","COM023",0)
THEN
 RESPONSE #100
 SetGlobal("gpe_complet","COM023",1)
END

// Le groupe est au complet: le Sphinx se reveille et demande au groupe d'approcher **********************************************************************************
IF
 Global("gpe_complet","COM023",1)
THEN
 RESPONSE #100
 
 // Le Sphinx se reveille et parle au groupe
 OpenDoor("SPHOFF")
 Wait(2)
 CreateCreature("COSPHIN",[882.351],10) 
 ActionOverride("COSPHIN",StartDialogueNoSet([PC])) 
 
 // L'écran de feu 1 disparait
 Wait(2)
 PlaySound("EFF_E04")
 SmallWait(10)
 AmbientActivate("Wall1",FALSE)
 AmbientActivate("Wall2",FALSE)
 SoundActivate("MURFLAM1",FALSE)
 OpenDoor("CHAMPF")
 SetGlobal("wall_1_inactif","COM023",1)
 
 // L'écran de feu 2 apparait
 AmbientActivate("Wall3",TRUE)
 AmbientActivate("Wall4",TRUE)
 SoundActivate("MURFLAM2",TRUE)
 CloseDoor("CHAMPF2")  
END

// Le groupe n'est pas au complet: Le sphinx demande au groupe d'ętre complet **************************************************************************************************************************************
IF
 Global("wall_1_inactif","COM023",0)
 Global("gpe_complet","COM023",0)
 Global("gpe_incomplet","COM023",0)
THEN
 RESPONSE #100 
 SetGlobal("gpe_incomplet","COM023",1)
 
 // Le Sphinx se reveille et parle au groupe
 OpenDoor("SPHOFF")
 Wait(2)
 CreateCreature("COSPHIN",[882.351],10) 
 ActionOverride("COSPHIN",StartDialogueNoSet([PC]))
END 

// Maladie: arręt de la recherche du Player1: relance recherche *******************************************************************************************************************
IF
 GlobalTimerExpired("TIME_MALADIE_RECHERCHE","COM023")
 Global("MALADIE_RECHERCHE","COM023",1)
THEN
 RESPONSE #100
 SetGlobal("MALADIE_RECHERCHE","COM023",0)
 
 ClearActions("COMALAD") 
END

// Maladie est vaincue: l'écran de feu 2 disparait *******************************************************************************************************************************
IF
 Global("MALADIE_MEURT","GLOBAL",1)
THEN
 RESPONSE #100
 SetGlobal("MALADIE_MEURT","GLOBAL",2)
 
 // L'écran de feu 2 apparait
 PlaySound("EFF_E04")
 SmallWait(10)
 AmbientActivate("Wall3",FALSE)
 AmbientActivate("Wall4",FALSE)
 SoundActivate("MURFLAM2",FALSE)
 OpenDoor("CHAMPF2")  
END



