IF
 Global("com026_init","COM026",0)
THEN
 RESPONSE #100
 SetGlobal("com026_init","COM026",1)
  
 CreateCreature("RAT",[255.275],6)   
 CreateCreature("RAT",[540.213],6)  
 CreateCreature("RAT",[700.300],6)  
END


// Quęte barni: condamner la cave et reprise de la clé.
IF
 Global("Barni_quete","GLOBAL",5)  
THEN
 RESPONSE #100
 SetGlobal("Barni_quete","GLOBAL",6)
 CloseDoor("TRAPPE01")
 Lock("TRAPPE01")
END

// Le groupe a débloqué la porte du temple et remonte ŕ l'auberge: Candelas les attends dans la cave.
IF
 Global("candelas_init","COM026",0)
 Global("Crane_place","GLOBAL",1)
THEN
 RESPONSE #100
 SetGlobal("candelas_init","COM026",1)
 
 createcreature("COCANDE",[340.340],10)
END

// Fin du dialogue avec Candelas: combat
IF
 Global("candelas_init","COM026",2)
THEN
 RESPONSE #100
 SetGlobal("candelas_init","COM026",3)
 
 AddJournalEntry(@7,QUEST) 
 ChangeEnemyAlly("COCANDE",ENEMY)
 DisplayStringHead("COCANDE",@100)
 
 ChangeEnemyAlly("COEKILIS",ENEMY)
 DisplayStringHead("COEKILIS",@101)
  
 // Tueurs de Cyric
 createcreature("COCYRv1",[277.232],15) 
 createcreature("COCYRv1",[604.201],15)
 createcreature("COCYRv1",[446.236],15)
  
 // Guerriers de Cyric
 createcreature("COCYRG1",[260.146],15)
 SmallWait(50)
 createcreature("COCYRG1",[260.146],15)
 smallWait(50)
 createcreature("COCYRG1",[260.146],15)
END

// Quęte terminée "Histoire du temple de Bhaal": prise en compte des infos trouvées
// Cas 1: Rencontre Massena + discut Systera Systéra Elu + discut Candelas + Champion de Bhaal + présence Ekilis
IF
 !ActuallyIncombat()
 Global("candelas_init","COM026",3) 
 Global("Champion_bhaal","GLOBAL",1) 
 Global("Fin_quete_hist_bhaal","COM026",0)
 AreaCheckObject("COM026","COEKILIS")
THEN
 RESPONSE #100
 SetGlobal("Fin_quete_hist_bhaal","COM026",1)
  
 EraseJournalEntry(@1)
 EraseJournalEntry(@2) 
 EraseJournalEntry(@3)
 EraseJournalEntry(@4) 
 EraseJournalEntry(@5)
 EraseJournalEntry(@6) 
 EraseJournalEntry(@7) 
 AddJournalEntry(@15,QUEST_DONE)
 AddexperienceParty(2000)
 
 // Karl démasqué 
 EraseJournalEntry(@50)
 EraseJournalEntry(@51)
 EraseJournalEntry(@52)
 EraseJournalEntry(@53)
 EraseJournalEntry(@54)
 AddJournalEntry(@55,QUEST_DONE)
 AddexperienceParty(500)
END

