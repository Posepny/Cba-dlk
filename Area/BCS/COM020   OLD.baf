IF
 Global("GLOBAL_init","GLOBAL",0)
THEN
 RESPONSE #100
 SetGlobal("GLOBAL_init","GLOBAL",1)
 
 Createcreature("COISLEN",[1690.1160],10)   
 Createcreature("COBASIL1",[1310.1005],10)    
 Createcreature("COBATIN",[200.240],10) 
 Createcreature("COBATIN",[160.235],10) 
 Createcreature("COBATIN",[1530.350],10) 
 Createcreature("COBATIN",[1380.920],10) 
 Createcreature("COBATIN",[900.640],10) 
 Createcreature("COBATIN",[340.680],10) 
 Createcreature("COBATIN",[460.990],10) 
 Createcreature("COBATIN",[1190.140],10) 
 Createcreature("COBATIN",[750.1200],10) 
 
 Wait(3)
 DisplaystringHead("COISLEN",@1)
  
 CloseDoor("GRILLE1")
 Lock("GRILLE1")
 TriggerActivation("COM021",FALSE)
 SetGlobal("Acces_COM021","GLOBAL",1)    
 
 CloseDoor("GRILLE2")
 Lock("GRILLE2")
 TriggerActivation("COM019",FALSE)  
 SetGlobal("Acces_COM019","GLOBAL",1) 
 
 SetGlobalTimer("T_COISLEN_chasse","GLOBAL",1) 
END


// Islendra est en chasse et elle poursuit quelqu'un ŕ l'étage supérieur: arręt de la chasse et redescente aussitôt ********************************************************
IF
 Global("COM020_COISLEN_DESC","GLOBAL",1)
THEN 
 RESPONSE #100
 SetGlobal("COM020_COISLEN_DESC","GLOBAL",0)
 CreateCreature("COISLEN",[1160.125],15)
END


// Islendra gestion de la chasses ******************************************************************************************************************
IF
 GlobalTimerExpired("T_COISLEN_chasse","GLOBAL")
 Global("COISLEN_chasse","GLOBAL",1)
 OR(6)
  AreaCheckObject("COM020",PLAYER1)
  AreaCheckObject("COM020",PLAYER2)
  AreaCheckObject("COM020",PLAYER3)
  AreaCheckObject("COM020",PLAYER4)
  AreaCheckObject("COM020",PLAYER5)
  AreaCheckObject("COM020",PLAYER6)
THEN
 RESPONSE #100
 ClearActions("COISLEN")
 SetGlobal("COISLEN_chasse","GLOBAL",2)
 
 Createcreature("MINSC",[400.450],10)  
END



