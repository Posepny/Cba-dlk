// Téléportation duel Islendra ****************************************************************************************************************************************************
IF
 Global("COM020_PNJ_capture","GLOBAL",1)
 AreaCheckObject("COM020","COISLEN") 
THEN
 RESPONSE #100
 SetGlobal("COM020_PNJ_capture","GLOBAL",2)
 

 ActionOverride("COISLEN",DestroyItem("arop01"))
 //CreateVisualEffectObject("SPMAZE1",Lastseenby("COISLEN"))
 Wait(1)
 ActionOverride(Lastseenby("COISLEN"),JumpToPoint([360.665])) // Téléportation de la cible  
END

// Arrivée de Islendra ŕ son tour
IF
 Global("COM020_PNJ_capture","GLOBAL",2)
 AreaCheckObject("COM020","COISLEN") 
THEN
 RESPONSE #100
 SetGlobal("COM020_PNJ_capture","GLOBAL",3)
 
 Createcreature("MINSC",[360.665],10)  
 
 
 CreateVisualEffectObject("SPMAZE1","COISLEN")
 Wait(1)
 ActionOverride("COISLEN",JumpToPoint([250.825]))
END 

// Arrivée de Islendra ŕ son tour
IF
 Global("COM020_PNJ_capture","GLOBAL",2)
 !AreaCheckObject("COM020","COISLEN") 
THEN
 RESPONSE #100
 SetGlobal("COM020_PNJ_capture","GLOBAL",3)
 
 Createcreature("MINSC",[360.665],10) 
 Createcreature("MINSC",[360.665],10) 
 
 CreateVisualEffectObject("SPMAZE1","COISLEN")
 Wait(1)
 ActionOvErride("COISLEN",LeaveAreaLUA("COM020","",[250.825],1))
END 

// Glabuk apparait dans la zone de duel 
IF
 Global("Glabuk_apparition","GLOBAL",1)
 AreaCheckObject("COM020","COISLEN") 
THEN
 RESPONSE #100
 SetGlobal("Glabuk_apparition","GLOBAL",2)
 
 ActionOverride("cobasil1",JumpToPoint([250.825]))
 ForceSpell("cobasil1",GREY_MUSHROOM)
END


// Gestion de la corde **********************************************************************************************************************************************************************
// La corde a été lancée du niveau sup, on peut grimper ŕ la corde qui est visible.
IF 
 Global("Corde_lancee1","GLOBAL",1)
 Global("Corde_grimper1","GLOBAL",0)
THEN
 RESPONSE #100
 SetGlobal("Corde_grimper1","GLOBAL",1)
 
 // Gestion graphique 
 closeDoor("CORD1")
   
 // Activation gestion de la corde
 TriggerActivation("COT020C1",TRUE)
END

