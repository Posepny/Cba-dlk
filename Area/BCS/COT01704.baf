// Sarcophage fermť
IF
  Clicked([ANYONE])
  !Range(LastTrigger,6)
THEN
  RESPONSE #100
  DisplayStringHead(Myself,@7) 
END

IF
  Clicked([ANYONE])
  Range(LastTrigger,6)
THEN
  RESPONSE #100
  DisplayStringHead(LastTrigger,@3) 
END

// Sarcophage ouvert
IF
  Opened([ANYONE])
THEN
  RESPONSE #100
  DisplayStringHead(LastTrigger,@4)  
END