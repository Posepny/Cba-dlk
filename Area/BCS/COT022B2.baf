IF
 Clicked([ANYONE])
 Global("bassin2_click","COM022",0)
 !Range(lasttrigger,7)
THEN
 RESPONSE #100
 ActionOverride(lasttrigger,MoveToObject("Cot022b2"))
END

IF
 Clicked([ANYONE])
 Global("bassin2_click","COM022",0)
 !HasItem("MISCP55",LastTrigger)
 Range(lasttrigger,7)
THEN
 RESPONSE #100
 //SetGlobal("bassin2_click","COM022",1)
 // ~Sous le bassin vous distinguez une vanne. La tourner devrait vider le bassin mais vous n'avez pas d'outil.~
 DisplayStringHead(LastTrigger,@1)
END

IF
 Clicked([ANYONE])
 Global("bassin2_click","COM022",0)
 HasItem("MISCP55",LastTrigger)
 Range(lasttrigger,7)
THEN
 RESPONSE #100
 SetGlobal("bassin2_click","COM022",1)
 // ~Sous le bassin vous distinguez une vanne. Avec l'outil, la tourner devrait vider le bassin.~
 DisplayStringHead(LastTrigger,@2)
END

IF
 Clicked([ANYONE])
 Global("bassin2_click","COM022",1)
 HasItem("MISCP55",LastTrigger)
 CheckStatLT(LastTrigger,11,STR)
 Range(lasttrigger,7)
THEN
 RESPONSE #100
 //~Vous utilisez l'outil pour fermer la vanne mais elle rÕsiste, vous manquez de force.~
 DisplayStringHead(LastTrigger,@3)
END

IF
 Clicked([ANYONE])
 Global("bassin2_click","COM022",1)
 HasItem("MISCP55",LastTrigger)
 CheckStatGT(LastTrigger,11,STR)
 Range(lasttrigger,7)
THEN
 RESPONSE #100
 SetGlobal("bassin2_click","COM022",2)
 
 // ~Vous bandez vos muscles et parvenez Á ouvrir la vanne avec l'outil. Le bassin se vide.~
 DisplayStringHead(LastTrigger,@4)
 
 // image Bassin vidÕ
 CloseDoor("Bassg2")
 
 SoundActivate("COM022B2",FALSE)
 TriggerActivation("Cot022b2",FALSE)
END
