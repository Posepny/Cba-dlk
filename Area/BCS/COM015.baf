IF
 Oncreation()
 Global("COM015_init","GLOBAL",0)
THEN
 RESPONSE #100
 SetGlobal("COM015_init","GLOBAL",1)
  
  //GRILLE FERMEE
  CloseDoor("DOOR0002") 
  CloseDoor("DOOR0003") 
  
  // PS sarcophage non trouvé
  TriggerActivation("DOOR016",FALSE)
      
  // Gestion des wyvernes
  Createcreature("WYVERN",[510.950],10) 
  GiveItem("MISC52","WYVERN")
  Createcreature("WYVERBA",[510.950],10)     
  Createcreature("WYVERBA",[510.950],10)  
  
  // Positionnement des prisonniers dans les cellules
  Createcreature("TROLL01",[3900.1690],10)     
  Createcreature("TROLL01",[3900.1690],10)  
  Createcreature("COUMBER",[2880.2115],10)     
  Createcreature("COUMBER",[2880.2115],10)    
  
  // positionnement de Massena
  Createcreature("COMASSE1",[1990.790],6) 
  SmallWait(10)
  ActionOverride("COMASSE1",SetDialogue("COMASSE2"))
  SmallWait(10)
  DeActivate("COMASSE1")    
  
  // Cache Batons de commandements
  ContainerEnable("Container019",FALSE)	
  ContainerEnable("Container020",FALSE)
    
  // Ajout des chauves-souris
  CreateCreature("COBAT2",[2770.1360],0)
  CreateCreature("COBAT2",[2920.1770],0)
  CreateCreature("COBAT2",[3350.1640],0)
  CreateCreature("COBAT2",[3530.1900],0)
  CreateCreature("COBAT2",[4070.1870],0)  
  CreateCreature("COBAT2",[4140.1970],0)
  CreateCreature("COBAT2",[3240.2040],0) 
  CreateCreature("COBAT2",[2450.2300],0) 
  CreateCreature("COBAT2",[2770.1360],0)
  CreateCreature("COBAT2",[2920.1770],0)
  CreateCreature("COBAT2",[3350.1640],0)
  CreateCreature("COBAT2",[3530.1900],0)
  CreateCreature("COBAT2",[4070.1870],0)  
  CreateCreature("COBAT2",[4140.1970],0)
  CreateCreature("COBAT2",[3240.2040],0) 
  CreateCreature("COBAT2",[2450.2300],0) 
END


IF
  Disarmed("COT01515")
THEN
  RESPONSE #100
    //PlaySound("COBOO1")
	wait(2)
	//PlaySound("COBOO1")
    TriggerActivation("COT01515",FALSE)
END


// Ekilis alerte le groupe que le coffre est pičgé. *********************************************************************************
IF
  Global("ekilis_alliance","GLOBAL",1)
  AreaCheckObject("COM015","COEKILIS")
  !Dead("COEKILIS")  
  Global("ekilis_coffre_piege","COM015",0)
THEN 
 RESPONSE #100
 SetGlobal("ekilis_coffre_piege","COM015",1)
 Wait(2)
 DisplayStringHead("COEKILIS",@9) // ~Attention, le coffre est ŕ éviter. Il est pičgé.~
END


// Livre d'Ekilis en possession du groupe ou révelation d'Ekilis: evolution histoire du temple + trésors de Bhaal ******************************************************************************
IF
 Global("livre_ekilis","GLOBAL",0) 
 PartyHasItemIdentified("BOKP07")
THEN
 RESPONSE #100
 SetGlobal("livre_ekilis","GLOBAL",1)
 SetGlobal("Q_tresor_bhaal","GLOBAL",1) 
  
 // Histoire de Bhaal
 AddJournalEntry(@70,QUEST)   
END

IF
 Global("Q_tresor_bhaal","GLOBAL",1)
THEN
 RESPONSE #100
 SetGlobal("Q_tresor_bhaal","GLOBAL",2) 

 // Le trésor de Bhaal 
 EraseJournalEntry(@50)
 EraseJournalEntry(@51)
 EraseJournalEntry(@52)
 EraseJournalEntry(@53)
 EraseJournalEntry(@54)
 AddJournalEntry(@55,QUEST_DONE)   
 AddXpObject(PLAYER1,1000)
END

// Le groupe prend les restes de Massena dans son équipement: le collier de massena apparait dans l'équipement *************************************************************
IF
 HasItem("Skelp01",PLAYER1)
 Global("collier_massena_init","GLOBAL",0)
THEN
 RESPONSE #100
 SetGlobal("collier_massena_init","GLOBAL",1)
 SetGlobal("collier_TP_PLAYER","GLOBAL",1)
 ActionOverride(PLAYER1,CreateItem("AMUP02",0,0,0)) 
END

