// Le cadavre de Massena n'est plus dans l'équipement du groupe: le collier disparait. *************************************************************************************
IF
 !PartyHasItem("Skelp01")
 PartyHasItem("AMUP02") 
 Global("collier_massena_init","GLOBAL",1)
THEN
 RESPONSE #100
 SetGlobal("collier_massena_init","GLOBAL",0)
 TakePartyItem("AMUP02")
END


// attente avant nouvelle TP possible avant le collier de Massena **************************************************************************************************************************
IF
 Global("TimeTP14","GLOBAL",1)
 GlobalTimerExpired("TIMER_init_TP","GLOBAL") 
THEN
 RESPONSE #100
 sETGlobal("TimeTP14","GLOBAL",0)  
 SetGlobal("TimeTP","GLOBAL",0)  
END

IF
 Global("TimeTP15","GLOBAL",1) 
 GlobalTimerExpired("TIMER_init_TP","GLOBAL")
THEN
 RESPONSE #100
 sETGlobal("TimeTP15","GLOBAL",0)  
 SetGlobal("TimeTP","GLOBAL",0)  
END

// Ekilis devient l'allié du groupe: il sera dans chaque carte oů le PNJ qu'il suit prend une sortie **************************************************************************************************************************
IF
  Global("ekilis_alliance","GLOBAL",1)
  !AreaCheckObject("COM015","COEKILIS")
  !Dead("COEKILIS")  
  AreaCheckObject("COM015",PLAYER1)
  Global("ekilis_follow","GLOBAL",1)
  Global("TimeTP","GLOBAL",0)
THEN
  RESPONSE #100
  //Createcreature("MINSC",[870.1370],10)  
  MoveGlobalObject("COEKILIS",PLAYER1)

  wait(2)
  SetGlobal("ekilis_follow","GLOBAL",0)
END

