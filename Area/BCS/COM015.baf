// nouvelle vague
IF
 DELAY(10)
  OR(5)
   Global("recup_pierre_top_poison","GLOBAL",1) 
   Global("recup_pierre_top_froid","GLOBAL",1) 
   Global("recup_pierre_top_poison","GLOBAL",1) 
   Global("recup_pierre_top_acide","GLOBAL",1) 
   Global("recup_pierre_top_elec","GLOBAL",1)    
THEN
 RESPONSE #100
 SetGlobal("recup_pierre_top_poison","GLOBAL",0) 
 SetGlobal("recup_pierre_top_froid","GLOBAL",0) 
 SetGlobal("recup_pierre_top_poison","GLOBAL",0) 
 SetGlobal("recup_pierre_top_acide","GLOBAL",0) 
 SetGlobal("recup_pierre_top_elec","GLOBAL",0)  
END

// Mort de la grande Wyvern: sa tęte est ŕ placer dans la cache pour ouvrir le PS **************************************************************************************************************************
IF
 HasItem("MISC52","Container018")
 HasItem("MISC52","Container017")
 OpenState("DOOR0001",FALSE)
THEN
  RESPONSE #100  
  OpenDoor("DOOR0001")
  SetGlobal("COT01501","COM015",3)
  PlaySound("EFF_M15")
END

/*
// Grande grille ouverte: bruit grille
IF 
 OpenState("DOOR0001",TRUE)
THEN
 RESPONSE #100
 Playsound("AMB_D01A")
END
*/

// La porte a été fermée. Au bou d'un certain temps le PS s'ouvre ŕ nouveau **************************************************************************************************************************
IF
  GlobalTimerExpired("Com015_PS_ferme","COM015")
  Global("COT01501","COM015",2) 
THEN
  RESPONSE #100
  SetGlobal("COT01501","COM015",3)
  PlaySound("EFF_M15")
END

// baton de commandement 1: cache découverte **************************************************************************************************************************
IF
  OpenState("DOOR0008",TRUE)		
  Global("BatonC1","COM015",0)
THEN
  RESPONSE #100
  SetGlobal("BatonC1","COM015",1)	
  ContainerEnable("Container019",TRUE)	// container accessible si le PS est découvert
END

// baton de commandement 2: cache découverte **************************************************************************************************************************
IF
  OpenState("DOOR0009",TRUE)		
  Global("BatonC2","COM015",0)
THEN
  RESPONSE #100
  SetGlobal("BatonC2","COM015",1)	
  ContainerEnable("Container020",TRUE)	// container accessible si le PS est découvert
END

// gestion de la grille en fonction de la position de l'actionneur **************************************************************************************************************************
IF
  OpenState("DOOR0003",TRUE)
  OpenState("DOOR0002",FALSE)
THEN
 RESPONSE #100 
 OpenDoor("DOOR0002")
 Playsound("AMB_D01A")
 SetGlobal("COM015_grille","GLOBAL",1)
END

IF
  OpenState("DOOR0003",FALSE)
  OpenState("DOOR0002",TRUE)
THEN
 RESPONSE #100 
 CloseDoor("DOOR0002") 
 Playsound("AMB_D01A")
 SetGlobal("COM015_grille","GLOBAL",0) 
END

// Gestion du PS sarcophage **************************************************************************************************************************
IF
  OpenState("DOOR0004",TRUE)    
THEN
 RESPONSE #100 
 TriggerActivation("DOOR016",TRUE) 
END

IF
  OpenState("DOOR0004",FALSE)  
THEN
 RESPONSE #100 
 TriggerActivation("DOOR016",FALSE)  
END


