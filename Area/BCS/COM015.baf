// DLG Massena terminé ***************************************************************************************************************************************************************************************
IF
 Global("ekilis_deactivate","Global",1)
THEN
 RESPONSE #100
 SetGlobal("ekilis_deactivate","Global",0)
 
 Wait(2)
 Deactivate("COMASSE1")
END

IF
 Global("fin_dial_massena","Global",0)
 Global("Massena_sarcophage","Global",1)
THEN
 RESPONSE #100
 SetGlobal("fin_dial_massena","Global",1)
 
 Deactivate("COMASSE1")
END


// Tantqu'il manque des pierres dans le coffre, les créatures apparaissent et s'attaquent au propriétaire. *************************************************************
IF
 GlobalLT("recup_pierre_feu","GLOBAL",3)
 !Contains("MISC16","Con01513")
 Global("recup_pierre_top_feu","GLOBAL",0) 
THEN
 RESPONSE #100
 IncrementGlobal("recup_pierre_feu","GLOBAL",1)
 SetGlobal("recup_pierre_top_feu","GLOBAL",1) 
 CreateCreature("GIBBER_F",[828.1300],10)
 
 RESPONSE #100
 IncrementGlobal("recup_pierre_feu","GLOBAL",1)
 SetGlobal("recup_pierre_top_feu","GLOBAL",1) 
 CreateCreature("GIBBER_F",[903.1372],10)
END

