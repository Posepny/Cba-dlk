 Global("Corde_grimper1","GLOBAL",1)
THEN
 RESPONSE #100
 SetGlobal("Corde_grimper1","GLOBAL",0)
 
 // Gestion graphique 
 OpenDoor("CORD1")
   
 // Activation gestion de la corde
