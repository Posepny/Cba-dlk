// Un PLAYER monte ŕ la corde mais n'est pas assez doué. Il chute.
IF
 Global("Corde_chuter_player","GLOBAL",1)
THEN
 RESPONSE #100
 SetGlobal("Corde_chuter_player","GLOBAL",0) 
 ActionOverride(PLAYER1,PlayDead(100))
END

