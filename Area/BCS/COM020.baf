IF
 Global("GLOBAL_init","GLOBAL",0)
THEN
 RESPONSE #100
 SetGlobal("GLOBAL_init","GLOBAL",1)
 
 Createcreature("COBATIN",[200.240],10) 
 Createcreature("COBATIN",[160.235],10) 
 Createcreature("COBATIN",[1530.350],10) 
 Createcreature("COBATIN",[1380.920],10) 
 Createcreature("COBATIN",[900.640],10) 
 Createcreature("COBATIN",[340.680],10) 
 Createcreature("COBATIN",[460.990],10) 
 Createcreature("COBATIN",[1190.140],10) 
 Createcreature("COBATIN",[750.1200],10) 
 
 Createcreature("COBASIL1",[1310.1005],10)  
 
 Wait(3)
 
 // lorsqu'un membre du groupe entre dans le sous-sol, les portes se ferment: enfermé avec Islendra
 CloseDoor("GRILLE1")
 Lock("GRILLE1")
 TriggerActivation("COM022",FALSE)
 SetGlobal("COM020_grille1","GLOBAL",0) 
 SetGlobal("ordre_GR_20-22","GLOBAL",0) 
 PlaySound("AM0301B3")
 
 CloseDoor("GRILLE2")
 Lock("GRILLE2")
 TriggerActivation("COM019",FALSE)  
 SetGlobal("COM020_grille2","GLOBAL",0)  
 SetGlobal("ordre_GR_20-19","GLOBAL",0)
 PlaySound("AM0301B3")
END

// DEBUT Gestion de la grille Salle Grotte - Salle Bassins ***************************************************************************************************************************
// Grille1 grotte ouverte: elle doit l'ętre du côté bassin aussi
IF
  OpenState("GRILLE1",TRUE)
  Global("COM020_grille1","GLOBAL",0) 
  Global("ordre_GR_20-22","GLOBAL",0) 
THEN
 RESPONSE #100
 SetGlobal("COM020_grille1","GLOBAL",1) 
 TriggerActivation("COM022",TRUE)
END

// Grille1 grotte fermée: elle doit l'ętre du côté bassin aussi
IF
 OpenState("GRILLE1",FALSE)
 Global("COM020_grille1","GLOBAL",1) 
 Global("ordre_GR_20-22","GLOBAL",0) 
THEN
 RESPONSE #100
 SetGlobal("COM020_grille1","GLOBAL",0) 
 TriggerActivation("COM022",FALSE)
END

// Grille2 Bassin ouverte: elle doit l'ętre du côté grotte aussi
IF
 OpenState("GRILLE1",FALSE)
 Global("COM022_grille2","GLOBAL",1)  
 Global("ordre_GR_20-22","GLOBAL",1)
THEN
 RESPONSE #100
 UnLock("GRILLE1")
 OpenDoor("GRILLE1")
 TriggerActivation("COM022",TRUE)
 PlaySound("AM0301B3")
 SetGlobal("COM020_grille1","GLOBAL",1) 
END

// Grille2 Bassin fermée: elle doit l'ętre du côté grotte aussi
IF
 OpenState("GRILLE1",TRUE)
 Global("COM022_grille2","GLOBAL",0)  
 Global("ordre_GR_20-22","GLOBAL",1)
THEN
 RESPONSE #100
 CloseDoor("GRILLE1")
 Lock("GRILLE1")
 TriggerActivation("COM022",FALSE)
 PlaySound("AM0301B3")
 SetGlobal("COM020_grille1","GLOBAL",0) 
END
// FIN Gestion de la grille Salle Grotte - Salle Bassins ***************************************************************************************************************************


// DEBUT Gestion de la grille Salle Grotte - Salle Damiers ***************************************************************************************************************************
// Grille2 grotte ouverte: elle doit l'ętre du côté Damiers aussi
IF
  OpenState("GRILLE2",TRUE)
  Global("COM020_grille2","GLOBAL",0) 
  Global("ordre_GR_20-19","GLOBAL",0) 
THEN
 RESPONSE #100
 SetGlobal("COM020_grille2","GLOBAL",1) 
 TriggerActivation("COM019",TRUE)
 
 
 //PlaySound("COBOO1") // TEMOIN
END

// Grille1 grotte fermée: elle doit l'ętre du côté bassin aussi
IF
 OpenState("GRILLE2",FALSE)
 Global("COM020_grille2","GLOBAL",1) 
 Global("ordre_GR_20-19","GLOBAL",0) 
THEN
 RESPONSE #100
 SetGlobal("COM020_grille2","GLOBAL",0) 
 TriggerActivation("COM019",FALSE)
 
 
 //PlaySound("COBOO1") // TEMOIN
END

// FIN Gestion de la grille Salle Grotte - Salle Damiers ***************************************************************************************************************************







// Islendra: position aléatoire ŕ l'arrivée du groupe ********************************************************************************************************************
IF
 Global("COISLEN_position","COM020",0)
THEN
 RESPONSE #70
 SetGlobal("COISLEN_position","COM020",1)
 CreateCreature("COISLEN",[1540.345],15)
  
 RESPONSE #80
 SetGlobal("COISLEN_position","COM020",1)
 CreateCreature("COISLEN",[1600.640],15)
 
 RESPONSE #100
 SetGlobal("COISLEN_position","COM020",1)
 CreateCreature("COISLEN",[1750.1215],15)
END 


// Islendra est en chasse ************************************************************************************************************************************************
IF
 Global("COM020_chasse","GLOBAL",0)
THEN 
 RESPONSE #100
 SetGlobal("COM020_chasse","GLOBAL",1)
 ActionOverride("COISLEN",RandomWalk())
END

// Téléportation duel Islendra ****************************************************************************************************************************************************
IF
 Global("COM020_PNJ_capture","GLOBAL",1)
 AreaCheckObject("COM020","COISLEN") 
THEN
 RESPONSE #100
 SetGlobal("COM020_PNJ_capture","GLOBAL",2)
 

 ActionOverride("COISLEN",DestroyItem("arop01"))
 //CreateVisualEffectObject("SPMAZE1",Lastseenby("COISLEN"))
 Wait(1)
 ActionOverride(Lastseenby("COISLEN"),JumpToPoint([360.665])) // Téléportation de la cible  
END

// Arrivée de Islendra ŕ son tour
IF
 Global("COM020_PNJ_capture","GLOBAL",2)
 AreaCheckObject("COM020","COISLEN") 
THEN
 RESPONSE #100
 SetGlobal("COM020_PNJ_capture","GLOBAL",3)
 
 //Createcreature("MINSC",[360.665],10)  
 
 
 CreateVisualEffectObject("SPMAZE1","COISLEN")
 Wait(1)
 ActionOverride("COISLEN",JumpToPoint([250.825]))
END 


// Arrivée de Islendra ŕ son tour
IF
 Global("COM020_PNJ_capture","GLOBAL",2)
 !AreaCheckObject("COM020","COISLEN") 
THEN
 RESPONSE #100
 SetGlobal("COM020_PNJ_capture","GLOBAL",3)
 
 //Createcreature("MINSC",[360.665],10) 
 //Createcreature("MINSC",[360.665],10) 
 
 CreateVisualEffectObject("SPMAZE1","COISLEN")
 Wait(1)
 ActionOvErride("COISLEN",LeaveAreaLUA("COM020","",[250.825],1))
END 



