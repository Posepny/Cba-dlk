// Gestion de la corde **********************************************************************************************************************************************************************
// La corde a été lancée du niveau sup, on peut grimper ŕ la corde qui est visible.
IF 
 Global("Corde_lancee1","GLOBAL",1)
 Global("Corde_grimper1","GLOBAL",0)
THEN
 RESPONSE #100
 SetGlobal("Corde_grimper1","GLOBAL",1)
 
 // Gestion graphique 
 closeDoor("CORD1")
   
 // Activation gestion de la corde
 TriggerActivation("COT020C1",TRUE)
END

IF 
 Global("Corde_lancee2","GLOBAL",1)
 Global("Corde_grimper2","GLOBAL",0)
