IF
  Isoverme(PLAYER1)
  HasItem("AMUP02",PLAYER1)
  Global("TimeTP","GLOBAL",0)
THEN
  RESPONSE #100
  SetGlobal("TimeTP","GLOBAL",1)
  SetGlobal("CIBLE_TP","GLOBAL",1)
  
  SetGlobal("TimeTP_EKI","GLOBAL",1)
  //Playsound("COBOO1") // TEMOIN

/*
  SetInterrupt(FALSE)  
  PlaySound("CAS_P07")
  ForceSpellRES("com015TP",PLAYER1)
  SetInterrupt(TRUE)  
*/

  SetInterrupt(FALSE)
   ForceSpellRES("COTPEND",PLAYER1) 
   PlaySound("CAS_P07")
   Wait(1)
   ActionOverride(PLAYER1,LeaveAreaLUA("COM014","",[640.450],10))
  SetInterrupt(TRUE)  
END

