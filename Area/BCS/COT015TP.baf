// Animation ŕ l'arrivée *******************************************
IF
 Isoverme(PLAYER1)
 HasItem("AMUP02",PLAYER1)
 Global("TimeTP","GLOBAL",1)
THEN
 RESPONSE #100
 SetGlobal("TimeTP","GLOBAL",2)

/*
 SetInterrupt(FALSE)
 PlaySound("CAS_P07")
 ForceSpellRES("com014TP",PLAYER1)
 SetInterrupt(TRUE)
*/

 SetInterrupt(FALSE)
  ForceSpellRES("COTPEND",PLAYER1) 
  PlaySound("CAS_P07")
  Wait(6)
  SetGlobal("TimeTP","GLOBAL",0) 
 SetInterrupt(TRUE)
END

