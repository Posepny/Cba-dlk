// PS fermť si personne sur le COT02104
IF
 GlobalTimerExpired("PS6_OUVERT","COM021")
 OpenState("PS6A",TRUE)
 Entered([0]) 
THEN
 RESPONSE #50  
 SetGlobal("PS6_ferme","COM021",1) 
   
 // Relance vťrification 
 SetGlobalTimer("PS6_OUVERT","COM021",2) 
END


