// DÈpart TP vers le niv0 - B: COM015, animation ‡ l'arrivÈe
IF
 Global("TimeTP","GLOBAL",1) 
 Global("CIBLE_TP","GLOBAL",1)
THEN
  RESPONSE #100
  SetGlobal("TimeTP","GLOBAL",3)
  SetGlobalTimer("TIMER_init_TP","GLOBAL",8)

//createcreature("GIBBER_A",[750.500],10)  

  
  ActionOverride(PLAYER1,LeaveAreaLUA("COM015","",[3000.1784],10))
  ActionOverride(PLAYER1,ChangeAIScript("",RACE)) 
  SetGlobal("CIBLE_TP","GLOBAL",0)  
END

IF
 Global("TimeTP","GLOBAL",1)
 Global("CIBLE_TP","GLOBAL",2)
THEN
  RESPONSE #100
  SetGlobal("TimeTP","GLOBAL",3)
  SetGlobalTimer("TIMER_init_TP","GLOBAL",8)

  ActionOverride(PLAYER2,LeaveAreaLUA("COM015","",[3000.1784],10))
  ACTIONOVERRIDE(PLAYER2,ChangeAIScript("",RACE))
  SetGlobal("CIBLE_TP","GLOBAL",0) 
END

