// personne sur la zone: la porte doit ętre fermée
IF
 !Range([0],2)
THEN
 RESPONSE #100  
 SetGlobal("Action1_PS5","COM021",0)
END

// un PLAYER ou une créature sur la zone: la porte doit ętre ouverte
IF
 Range([0],2)
THEN
 RESPONSE #100  
 SetGlobal("Action1_PS5","COM021",1)
END







