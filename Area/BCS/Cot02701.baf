// si le Charname arrive sur cette Zone, le PS s'ouvre
IF
 Entered(PLAYER1)
 Global("PS_ouvert","COM027",0)
THEN
 RESPONSE #100
 SetGlobal("PS_ouvert","COM027",1)
 
 DisplayStringHead(PLAYER1,@2)
 Wait(2)
 //PlaySound("AMB_D04A")  
 //Wait(2) 
 Unlock("DOOR0001" )
 OpenDoor("DOOR0001")
 TriggerActivation("Com012",TRUE)
 DisplayString(PLAYER1,@3)
END