// larme de sang de Maladie
IF
 Contains("Miscp41","STELE01")
THEN
 RESPONSE #100
 ActionOverride("STELE01",DestroyItem("Miscp41"))
 
 CreateVisualEffectObject("CODEATH","COMALAD")
 Deactivate("COMALAD")   
 
 CreateVisualEffectObject("CODEATH","cospidg")
 Deactivate("cospidg")   

 IncrementGlobal("NB_boss_dead","COM024",1)
END

// Les Boss sont éliminés: la porte du niveau suivant d'ouvre ****************************************************************************************************
IF
 Global("NB_boss_dead","COM024",7)
THEN
 RESPONSE #100
 SetGlobal("NB_boss_dead","COM024",8)
 
 //Createcreature("MINSC",[1400.720],10)  
 
 wait(10)
 Unlock("DOOR0001")
 OpenDoor("DOOR0001")
 PlaySound("COM024D2") 
END


// Kael allié
IF
 Global("KAEL_combat_allie","COM024",0)
 Global("CO_KAEL_ALLIE","GLOBAL",1)
 Exists("COKAEL")
THEN 
 RESPONSE #100
 SetGlobal("KAEL_combat_allie","COM024",1)
 ChangeEnemyAlly("COKAEL",ALLY)
END







  