// deux essais successifs pour prendre le contr¶le des crķatures
IF 
 Race(myself,130)
 Global("Command_WANP02","LOCALS",0)
THEN
 RESPONSE #100
  
 ChangeEnemyAlly(myself,CONTROLLED) 
 SetGlobal("Command_WANP02","LOCALS",1)
 Continue()
END


IF 
 Global("Command_WANP02","LOCALS",1)
 Race(myself,130)
THEN
 RESPONSE #100
 SetGlobal("Command_WANP02","LOCALS",2)
   
 ChangeEnemyAlly(myself,CONTROLLED)
 //Createcreature("Minsc",[990.560],10)
END